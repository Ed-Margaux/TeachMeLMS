# Copy this file to `.env.local` and fill in values. Never commit `.env.local`.

### Local database (Docker: docker compose up -d)
# DATABASE_URL="mysql://root:example_root_password@127.0.0.1:3307/lsm_db?serverVersion=8.0&charset=utf8mb4"

### Contact page (Google Forms or any embed HTML)
# Google Forms → Send → <> (Embed) — use embedded=true (not the plain viewform?usp= dialog URL)
# Example (Teach Me Contact Form):
# CONTACT_FORM_EMBED="<iframe src=\"https://docs.google.com/forms/d/e/1FAIpQLSfHo4FnYyv18rHpHgURxP_YVFJjBYcPphn762qaqMfnBC1rdA/viewform?embedded=true\" width=\"480\" height=\"720\" frameborder=\"0\" title=\"Teach Me contact form\">Loading…</iframe>"

### Google OAuth (Staff — Sign in with Google)
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs (Web application).
# Authorized JavaScript origins (add both if you use either):
#   http://127.0.0.1:8000
#   http://localhost:8000
# Authorized redirect URIs (must match exactly — path is /connect/google/check):
#   http://127.0.0.1:8000/connect/google/check
#   http://localhost:8000/connect/google/check
# Leave GOOGLE_OAUTH_REDIRECT_URI empty in .env.local so Symfony uses the current request URL.
# Production (Railway): must match Google Console → Authorized redirect URIs exactly:
#   https://teachmelms-production.up.railway.app/connect/google/check
# Also add Authorized JavaScript origin: https://teachmelms-production.up.railway.app
# GOOGLE_OAUTH_REDIRECT_URI=https://your-domain.com/connect/google/check
# APP_PUBLIC_URL=https://your-domain.com
# Production defaults also live in .env.prod (Railway build); override via Railway Variables or .env.prod.local at start.
# GOOGLE_OAUTH_CLIENT_ID=....apps.googleusercontent.com
# GOOGLE_OAUTH_CLIENT_SECRET=...
# GOOGLE_OAUTH_REDIRECT_URI=

### Email (Brevo SMTP — use a verified sender in Brevo for MAILER_FROM)
# MAILER_DSN=smtp://USERNAME@smtp-brevo.com:PASSWORD@smtp-relay.brevo.com:587
# MAILER_FROM="Teach Me <verified-sender@yourdomain.com>"

### Email (optional; use Mailtrap when SMTP is not activated)
# MAILER_DSN=null://null
# MAILER_FROM="Teach Me <noreply@localhost>"
