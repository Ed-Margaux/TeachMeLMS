{% extends 'base.html.twig' %}

{% block title %}Sign Up - Teach Me{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <style>
        body {
            background-image: url('{{ asset('img/chldrens.jpg') }}');
            background-size: cover;
            background-position: center;
            background-repeat: no-repeat;
            background-attachment: fixed;
            min-height: 100vh;
            display: flex;
            align-items: center;    
            justify-content: center;
            position: relative; 
        }
        body::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: linear-gradient(135deg, rgba(197, 54, 120, 0.7) 0%, rgba(237, 100, 166, 0.7) 100%);
            z-index: 0;
        }
        .register-container {
            background: rgba(252, 255, 233, 0.77);
            border-radius: 8px;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.15);
            padding: 2.5rem 2rem;
            max-width: 500px;
            width: 100%;
            position: relative;
            z-index: 1;
        }
        .register-logo {
            text-align: center;
            margin-bottom: 1.5rem;
        }
        .register-logo img {
            max-width: 200px;
            height: auto;
        }
        .register-title {
            text-align: center;
            color: #2c2c2c;
            font-weight: 600;
            margin-bottom: 1.5rem;
            font-size: 1.75rem;
        }
        .form-label {
            font-size: 14px;
            font-weight: 500;
            color: #2c2c2c;
            margin-bottom: 8px;
        }
        .form-control, .form-select {
            border-radius: 6px;
            border: 1px solid #e0e0e0;
            padding: 12px 16px;
            font-size: 16px;
        }
        .form-control:focus, .form-select:focus {
            border-color: #ED64A6;
            box-shadow: 0 0 0 0.2rem rgba(237, 100, 166, 0.25);
        }
        .btn-register {
            background: linear-gradient(135deg, #C53678, #ED64A6);
            border: none;
            color: white;
            font-weight: 600;
            padding: 12px;
            border-radius: 6px;
            width: 100%;
            font-size: 16px;
            transition: all 0.3s ease;
        }
        .btn-register:hover {
            background: linear-gradient(135deg, #B02D6B, #D8559A);
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(197, 54, 120, 0.3);
        }
        .alert {
            border-radius: 6px;
            border: none;
            font-size: 14px;
            padding: 12px 16px;
            margin-bottom: 1rem;
        }
        .alert-danger {
            background-color: #f8d7da;
            color: #721c24;
        }
        .alert-success {
            background-color: #d4edda;
            color: #155724;
        }
        .mb-3 {
            margin-bottom: 1rem !important;
        }
        .mb-4 {
            margin-bottom: 1.5rem !important;
        }
        .form-text {
            font-size: 12px;
            color: #666;
            margin-top: 4px;
        }
        .text-danger {
            color: #dc3545 !important;
            font-size: 14px;
            margin-top: 4px;
        }
        .login-link {
            text-align: center;
            margin-top: 1.5rem;
            color: #2c2c2c;
            font-size: 14px;
        }
        .login-link a {
            color: #ED64A6;
            text-decoration: none;
            font-weight: 500;
        }
        .login-link a:hover {
            text-decoration: underline;
        }
    </style>
{% endblock %}

{% block body %}
<div class="register-container">
    <div class="register-logo">
        <img src="{{ asset('img/tmMainlogo.png') }}" alt="Teach Me - Learn. Love. Language.">
    </div>
    <h1 class="register-title">Create Your Account</h1>

    {% for flash_error in app.flashes('error') %}
        <div class="alert alert-danger">
            {{ flash_error }}
        </div>
    {% endfor %}

    {% for flash_success in app.flashes('success') %}
        <div class="alert alert-success">
            {{ flash_success }}
        </div>
    {% endfor %}

    {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}
        <div class="row mb-3">
            <div class="col-md-6">
                {{ form_label(form.firstName, null, {'label_attr': {'class': 'form-label'}}) }}
                {{ form_widget(form.firstName) }}
                {{ form_errors(form.firstName) }}
            </div>
            <div class="col-md-6">
                {{ form_label(form.lastName, null, {'label_attr': {'class': 'form-label'}}) }}
                {{ form_widget(form.lastName) }}
                {{ form_errors(form.lastName) }}
            </div>
        </div>

        <div class="mb-3">
            {{ form_label(form.email, null, {'label_attr': {'class': 'form-label'}}) }}
            {{ form_widget(form.email) }}
            {{ form_errors(form.email) }}
        </div>

        <div class="mb-3">
            {{ form_label(form.plainPassword.first, null, {'label_attr': {'class': 'form-label'}}) }}
            {{ form_widget(form.plainPassword.first) }}
            {{ form_errors(form.plainPassword.first) }}
        </div>

        <div class="mb-4">
            {{ form_label(form.plainPassword.second, null, {'label_attr': {'class': 'form-label'}}) }}
            {{ form_widget(form.plainPassword.second) }}
            {{ form_errors(form.plainPassword.second) }}
        </div>

        <button class="btn btn-register" type="submit">
            Sign Up
        </button>
    {{ form_end(form) }}

    <div class="login-link">
        Already have an account? <a href="{{ path('app_login') }}">Log in</a>
    </div>
</div>
{% endblock %}

