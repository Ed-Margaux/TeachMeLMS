{% extends 'base.html.twig' %}

{% block title %}Create account — Teach Me{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Lato:ital,wght@0,400;0,600;0,700;1,400&family=Merriweather:ital,wght@0,700;0,900;1,700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="{{ asset('styles/public/public-footer.css') }}">
    <link rel="stylesheet" href="{{ asset('styles/public/login.css') }}">
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="{{ asset('js/password-toggle.js') }}" defer></script>
{% endblock %}

{% block body %}
<div class="login-page login-page--register">
    <div class="login-split login-split--register">
        <div class="login-split__panel">
            <header class="login-split__header">
                {% include 'partials/_tm_brand_logos.html.twig' with { variant: 'split' } %}
            </header>
            <div class="login-split__inner login-split__inner--register">
                <h1 class="login-split__title">Create your account</h1>
                <p class="login-split__lead">Personalized lessons, on your schedule.</p>

                {% for flash_error in app.flashes('error') %}
                    <div class="login-split__alert" role="alert">{{ flash_error }}</div>
                {% endfor %}
                {% for flash_success in app.flashes('success') %}
                    <div class="login-split__alert login-split__alert--success" role="status">{{ flash_success }}</div>
                {% endfor %}

                {{ form_start(form) }}
                    {{ form_errors(form) }}

                    <div class="login-split__fields-row">
                        <div class="login-split__field">
                            {{ form_label(form.firstName, null, {'label_attr': {'class': 'login-split__label'}}) }}
                            {{ form_widget(form.firstName) }}
                            {{ form_errors(form.firstName) }}
                        </div>
                        <div class="login-split__field">
                            {{ form_label(form.lastName, null, {'label_attr': {'class': 'login-split__label'}}) }}
                            {{ form_widget(form.lastName) }}
                            {{ form_errors(form.lastName) }}
                        </div>
                    </div>

                    <div class="login-split__field">
                        {{ form_label(form.email, null, {'label_attr': {'class': 'login-split__label'}}) }}
                        {{ form_widget(form.email) }}
                        {{ form_errors(form.email) }}
                    </div>

                    <div class="login-split__field">
                        {{ form_label(form.plainPassword.first, null, {'label_attr': {'class': 'login-split__label'}}) }}
                        {{ form_widget(form.plainPassword.first) }}
                        {{ form_errors(form.plainPassword.first) }}
                    </div>

                    <div class="login-split__field">
                        {{ form_label(form.plainPassword.second, null, {'label_attr': {'class': 'login-split__label'}}) }}
                        {{ form_widget(form.plainPassword.second) }}
                        {{ form_errors(form.plainPassword.second) }}
                    </div>

                    <button type="submit" class="login-split__submit">Create account</button>
                {{ form_end(form) }}

                <p class="login-split__register">
                    Already have an account?
                    <a href="{{ path('app_login') }}">Sign in</a>
                </p>

                <p class="login-split__legal">
                    By creating an account, you agree to Teach Me’s
                    <a href="{{ path('app_home') }}#terms">Terms of Service</a>
                    and
                    <a href="{{ path('app_home') }}#privacy">Privacy Policy</a>.
                </p>
            </div>
        </div>

        <div
            class="login-split__visual"
            aria-hidden="true"
            style="background-image: linear-gradient(135deg, rgba(26, 39, 68, 0.82) 0%, rgba(197, 54, 120, 0.28) 45%, rgba(255, 88, 65, 0.22) 100%), url('{{ asset('img/stud.jpg') }}'); background-size: cover; background-position: center;"
        ></div>
    </div>
</div>
{% endblock %}
