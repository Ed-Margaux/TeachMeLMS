{% extends 'admin/_layout.html.twig' %}

{% block title %}Lesson Details{% endblock %}
{% block admin_title %}Lesson Details{% endblock %}

{% block admin_content %}
<div class="card shadow-sm p-4">
    <div class="d-flex justify-content-between align-items-start mb-4">
        <h2 class="h4 mb-0">{{ lesson.title }}</h2>
        <div class="d-flex gap-2">
            <a href="{{ path('app_lessons_edit', {'id': lesson.id}) }}" class="btn btn-brand">Edit</a>
            <a href="{{ path('app_lessons_index') }}" class="btn btn-outline-secondary">Back to List</a>
        </div>
    </div>

    <div class="mb-3">
        <strong>Title:</strong>
        <p class="mb-0">{{ lesson.title }}</p>
    </div>
    <div class="mb-3">
        <strong>Course:</strong>
        <p class="mb-0">
            {% if lesson.course %}
                <a href="{{ path('app_course_show', {'id': lesson.course.id}) }}" class="badge bg-primary">{{ lesson.course.title }}</a>
            {% else %}
                <span class="text-muted">No course assigned</span>
            {% endif %}
        </p>
    </div>
    <div class="mb-3">
        <strong>Description:</strong>
        <p class="mb-0">{{ lesson.description ?: 'No description provided' }}</p>
    </div>
    <div class="mb-3">
        <strong>Scheduled At:</strong>
        <p class="mb-0">
            {% if lesson.scheduledAt %}
                {{ lesson.scheduledAt|date('Y-m-d H:i:s') }}
            {% else %}
                <span class="text-muted">Not scheduled</span>
            {% endif %}
        </p>
    </div>
    <div class="mb-3">
        <strong>Created At:</strong>
        <p class="mb-0">{{ lesson.createdAt ? lesson.createdAt|date('Y-m-d H:i:s') : 'N/A' }}</p>
    </div>
    {% if lesson.updatedAt %}
    <div class="mb-3">
        <strong>Updated At:</strong>
        <p class="mb-0">{{ lesson.updatedAt|date('Y-m-d H:i:s') }}</p>
    </div>
    {% endif %}
</div>
{% endblock %}






