{% extends 'admin/_layout.html.twig' %}

{% block title %}Lessons{% endblock %}
{% block admin_title %}Lessons (Sessions){% endblock %}

{% block admin_content %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="h4 mb-0">Lesson Management</h2>
    <a href="{{ path('app_lessons_new') }}" class="btn btn-brand">Add New Lesson</a>
</div>

<div class="card shadow-sm mb-4">
    <div class="card-body">
        <form method="get" class="d-flex gap-2">
            <input type="text" name="search" class="form-control" placeholder="Search lessons..." value="{{ search }}">
            <button type="submit" class="btn btn-outline-secondary">Search</button>
            {% if search %}
                <a href="{{ path('app_lessons_index') }}" class="btn btn-outline-secondary">Clear</a>
            {% endif %}
        </form>
    </div>
</div>

<div class="card shadow-sm">
    <div class="table-responsive">
        <table class="table table-brand align-middle mb-0">
            <thead>
                <tr>
                    <th>Title</th>
                    <th>Course</th>
                    <th>Description</th>
                    <th>Scheduled At</th>
                    <th>Created</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for lesson in lessons %}
                    <tr>
                        <td class="fw-semibold">{{ lesson.title }}</td>
                        <td>
                            {% if lesson.course %}
                                <span class="badge bg-primary">{{ lesson.course.title }}</span>
                            {% else %}
                                <span class="text-muted">No course</span>
                            {% endif %}
                        </td>
                        <td>
                            {% if lesson.description %}
                                {{ lesson.description|slice(0, 80) }}{% if lesson.description|length > 80 %}...{% endif %}
                            {% else %}
                                <span class="text-muted">-</span>
                            {% endif %}
                        </td>
                        <td>
                            {% if lesson.scheduledAt %}
                                {{ lesson.scheduledAt|date('Y-m-d H:i') }}
                            {% else %}
                                <span class="text-muted">Not scheduled</span>
                            {% endif %}
                        </td>
                        <td>{{ lesson.createdAt ? lesson.createdAt|date('Y-m-d') : '' }}</td>
                        <td>
                            <div class="d-flex gap-1">
                                <a href="{{ path('app_lessons_show', {'id': lesson.id}) }}" class="btn btn-sm btn-outline-primary" title="View">
                                    <i class="bi bi-eye"></i>
                                </a>
                                {% if is_granted('ROLE_ADMIN') or (lesson.createdBy and lesson.createdBy.id == app.user.id) %}
                                    <a href="{{ path('app_lessons_edit', {'id': lesson.id}) }}" class="btn btn-sm btn-outline-secondary" title="Edit">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <form method="post" action="{{ path('app_lessons_delete', {'id': lesson.id}) }}" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this lesson?');">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ lesson.id) }}">
                                        <button class="btn btn-sm btn-outline-danger" title="Delete">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                {% endif %}
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr><td colspan="6">No lessons found.</td></tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}

