{% extends 'admin/_layout.html.twig' %}

{% block title %}Users{% endblock %}
{% block admin_title %}Users{% endblock %}

{% block admin_content %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="h4 mb-0"> </h2>
    <a href="{{ path('app_admin_user_new') }}" class="btn btn-brand">Add New User</a>
</div>

<div class="card shadow-sm">
    <div class="table-responsive">
        <table class="table table-brand align-middle mb-0">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Role</th>
                    <th>Status</th>
                    <th>Created</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for user in users %}
                    <tr>
                        <td>{{ user.fullName }}</td>
                        <td>{{ user.email }}</td>
                        <td>
                            {% if 'ROLE_ADMIN' in user.roles %}
                                <span class="badge bg-danger">Admin</span>
                            {% elseif 'ROLE_STAFF' in user.roles %}
                                <span class="badge bg-primary">Staff</span>
                            {% else %}
                                <span class="badge bg-secondary">User</span>
                            {% endif %}
                        </td>
                        <td>
                            <span class="badge {% if user.status == 'active' %}bg-success{% else %}bg-secondary{% endif %}">
                                {{ user.status|capitalize }}
                            </span>
                        </td>
                        <td>{{ user.createdAt ? user.createdAt|date('Y-m-d') : '' }}</td>
                        <td>
                            <div class="d-flex gap-1">
                                <a href="{{ path('app_admin_user_edit', {'id': user.id}) }}" class="btn btn-sm btn-outline-secondary" title="Edit">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                {% if user.id != app.user.id %}
                                    <form method="post" action="{{ path('app_admin_user_delete', {'id': user.id}) }}" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this user?');">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ user.id) }}">
                                        <button class="btn btn-sm btn-outline-danger" title="Delete">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                {% endif %}
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr><td colspan="6">No users found.</td></tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}
