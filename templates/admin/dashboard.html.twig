{% extends 'admin/_layout.html.twig' %}

{% block title %}Dashboard{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('styles/admin-dashboard.css') }}">
{% endblock %}

{% block admin_title %}Dashboard{% endblock %}
{% block admin_page_intro %}{% endblock %}

{% set learner_mix = totalStudents + totalTutors %}
{% set pct_students_of_learners = learner_mix > 0 ? (100 * totalStudents / learner_mix)|round(0, 'common') : 100 %}
{% set activity_cap = 20 %}
{% set pct_today_activity = todayActivities >= activity_cap ? 100 : (activity_cap > 0 ? (100 * todayActivities / activity_cap)|round(0, 'common') : 0) %}
{% set catalog_mix = totalCourses + totalStudents %}
{% set pct_courses = catalog_mix > 0 ? (100 * totalCourses / catalog_mix)|round(0, 'common') : 0 %}

{% block admin_content %}
<script src="https://cdn.jsdelivr.net/npm/apexcharts"></script>

<div class="tm-dashboard">
    <header class="tm-dash-header">
        <div class="tm-dash-header-text">
            <h1 class="tm-dash-title">Dashboard</h1>
            <p class="tm-dash-sub">Welcome to Teach Me — your learning operations at a glance.</p>
        </div>
        <nav class="tm-dash-breadcrumb" aria-label="Breadcrumb">
            <a href="{{ path('app_home') }}">Home</a>
            <span aria-hidden="true"> &gt; </span>
            <span>Dashboard</span>
        </nav>
    </header>

    <div class="tm-metric-row">
        <article class="tm-metric-card tm-metric-card--primary">
            <div class="tm-metric-top">
                <div>
                    <p class="tm-metric-label">Total students</p>
                    <p class="tm-metric-value">{{ totalStudents }}</p>
                </div>
                <div class="tm-metric-icon-wrap" aria-hidden="true">
                    <i class="bi bi-people-fill"></i>
                </div>
            </div>
            <div class="tm-metric-sublines">
                <span>Courses: {{ totalCourses }}</span>
                <span>Tutors: {{ totalTutors }}</span>
            </div>
            <div class="tm-metric-bar" role="presentation">
                <div class="tm-metric-bar-fill" style="width: {{ pct_students_of_learners }}%;"></div>
            </div>
        </article>

        <article class="tm-metric-card tm-metric-card--light tm-metric-card--coral">
            <div class="tm-metric-top">
                <div>
                    <p class="tm-metric-label">Today&rsquo;s activity</p>
                    <p class="tm-metric-value">{{ todayActivities }}</p>
                </div>
                <div class="tm-metric-icon-wrap" aria-hidden="true">
                    <i class="bi bi-plus-lg"></i>
                </div>
            </div>
            <div class="tm-metric-sublines">
                <span>Events logged today across Teach Me.</span>
                <span>Active accounts: {{ activeUsers }} &middot; Staff: {{ totalStaff }}</span>
            </div>
            <div class="tm-metric-bar" role="presentation">
                <div class="tm-metric-bar-fill" style="width: {{ pct_today_activity }}%;"></div>
            </div>
        </article>

        <article class="tm-metric-card tm-metric-card--light tm-metric-card--accent">
            <div class="tm-metric-top">
                <div>
                    <p class="tm-metric-label">Total courses</p>
                    <p class="tm-metric-value">{{ totalCourses }}</p>
                </div>
                <div class="tm-metric-icon-wrap" aria-hidden="true">
                    <i class="bi bi-layers-fill"></i>
                </div>
            </div>
            <div class="tm-metric-sublines">
                <span>Catalog size vs. enrolled learners.</span>
                <span>Total users: {{ totalUsers }} &middot; Records: {{ totalRecords }}</span>
            </div>
            <div class="tm-metric-bar" role="presentation">
                <div class="tm-metric-bar-fill" style="width: {{ pct_courses }}%;"></div>
            </div>
        </article>
    </div>

    <div class="tm-dash-lower">
        <section class="tm-panel" aria-labelledby="tm-chart-heading">
            <div class="tm-panel-head">
                <h2 id="tm-chart-heading">Students &amp; tutors added</h2>
            </div>
            <div id="tm-dash-chart" role="img" aria-label="Bar chart of students and tutors added over the last 24 hours"></div>
        </section>

        <section class="tm-panel" aria-labelledby="tm-notify-heading">
            <div class="tm-panel-head">
                <h2 id="tm-notify-heading">Recent activity</h2>
                {% if is_granted('ROLE_ADMIN') %}
                <a href="{{ path('app_admin_logs') }}" class="tm-btn-ghost">View all</a>
                {% endif %}
            </div>
            {% if recentActivities|length > 0 %}
            <ul class="tm-notify-list">
                {% for activity in recentActivities %}
                <li class="tm-notify-item">
                    {% set act = activity.action|default('')|lower %}
                    <div class="tm-notify-icon {% if act == 'login' or act == 'logout' %}tm-notify-icon--log{% elseif act == 'create' %}tm-notify-icon--create{% else %}tm-notify-icon--muted{% endif %}" aria-hidden="true">
                        {% if act == 'delete' %}
                            <i class="bi bi-x-lg"></i>
                        {% elseif act == 'create' %}
                            <i class="bi bi-plus-lg"></i>
                        {% elseif act == 'update' %}
                            <i class="bi bi-pencil"></i>
                        {% elseif act == 'login' %}
                            <i class="bi bi-box-arrow-in-right"></i>
                        {% elseif act == 'logout' %}
                            <i class="bi bi-box-arrow-left"></i>
                        {% else %}
                            <i class="bi bi-question-lg"></i>
                        {% endif %}
                    </div>
                    <div class="tm-notify-body">
                        <strong>{{ activity.action }} &middot; {{ activity.targetType|capitalize }}</strong>
                        <span class="tm-notify-meta">
                            {% if activity.user %}{{ activity.user.fullName }}{% else %}System{% endif %}
                            {% if activity.targetLabel %} — {{ activity.targetLabel }}{% endif %}
                        </span>
                    </div>
                    <div class="tm-notify-when">
                        {% if activity.createdAt %}
                        <time datetime="{{ activity.createdAt|date('c') }}" class="tm-relative-time">{{ activity.createdAt|date('M j, Y') }} {{ activity.createdAt|date('H:i') }}</time>
                        {% endif %}
                    </div>
                </li>
                {% endfor %}
            </ul>
            {% else %}
            <p class="text-muted mb-0 small">No recent activity yet. Actions across Teach Me will appear here.</p>
            {% endif %}
        </section>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const isDarkMode = document.documentElement.getAttribute('data-theme') === 'dark';
    const textPrimary = getComputedStyle(document.documentElement).getPropertyValue('--text-primary').trim() || (isDarkMode ? '#e8e8e8' : '#2c2c2c');
    const textSecondary = getComputedStyle(document.documentElement).getPropertyValue('--text-secondary').trim() || (isDarkMode ? '#b8b8b8' : '#666');
    const borderLight = getComputedStyle(document.documentElement).getPropertyValue('--border-light').trim() || (isDarkMode ? '#333' : '#f0f0f0');

    const timelineData = {{ timelineData|json_encode|raw }};
    const categories = timelineData.categories || [];
    const studentsData = timelineData.studentsData || [];
    const tutorsData = timelineData.tutorsData || [];

    const options = {
        series: [
            { name: 'Students added', data: studentsData.length ? studentsData : [0, 0, 0, 0, 0, 0, 0] },
            { name: 'Tutors added', data: tutorsData.length ? tutorsData : [0, 0, 0, 0, 0, 0, 0] }
        ],
        chart: {
            type: 'bar',
            height: 320,
            width: '100%',
            toolbar: { show: true, tools: { download: false } },
            fontFamily: '"Lato", system-ui, sans-serif',
            redrawOnParentResize: true,
            redrawOnWindowResize: true
        },
        responsive: [
            {
                breakpoint: 992,
                options: {
                    chart: { height: 300 },
                    plotOptions: { bar: { columnWidth: '62%' } },
                    legend: { fontSize: '12px', offsetY: 2 }
                }
            },
            {
                breakpoint: 576,
                options: {
                    chart: { height: 268, toolbar: { show: false } },
                    plotOptions: { bar: { borderRadius: 4, columnWidth: '75%' } },
                    legend: { fontSize: '11px', position: 'bottom', horizontalAlign: 'center', offsetY: 4 },
                    grid: { padding: { left: 4, right: 4 } },
                    xaxis: { labels: { rotate: -40, rotateAlways: false, hideOverlappingLabels: true, maxHeight: 72, style: { fontSize: '10px' } } },
                    yaxis: { labels: { style: { fontSize: '10px' } } }
                }
            }
        ],
        colors: ['#FF5841', '#ED64A6'],
        plotOptions: {
            bar: {
                borderRadius: 6,
                columnWidth: '58%',
                dataLabels: { position: 'top' }
            }
        },
        dataLabels: { enabled: false },
        stroke: { show: true, width: 0 },
        xaxis: {
            type: 'datetime',
            categories: categories.length ? categories : undefined,
            labels: {
                style: { colors: textSecondary, fontSize: '11px' },
                datetimeUTC: false,
                format: 'HH:mm'
            }
        },
        yaxis: {
            labels: { style: { colors: textSecondary, fontSize: '11px' } }
        },
        legend: {
            position: 'bottom',
            fontSize: '13px',
            fontFamily: '"Lato", system-ui, sans-serif',
            labels: { colors: textPrimary }
        },
        grid: {
            borderColor: borderLight,
            strokeDashArray: 4,
            padding: { top: 12, right: 8, bottom: 0, left: 8 }
        },
        tooltip: {
            theme: isDarkMode ? 'dark' : 'light',
            x: { format: 'dd MMM yyyy HH:mm' }
        }
    };

    if (!categories.length) {
        options.xaxis = {
            categories: ['—', '—', '—', '—', '—', '—', '—'],
            labels: { style: { colors: textSecondary, fontSize: '11px' } }
        };
    }

    const el = document.querySelector('#tm-dash-chart');
    if (el && typeof ApexCharts !== 'undefined') {
        const chart = new ApexCharts(el, options);
        chart.render();

        var resizeChart = function() {
            try {
                chart.resize();
            } catch (e) { /* noop */ }
        };
        window.addEventListener('resize', resizeChart);
        window.addEventListener('orientationchange', resizeChart);
        if (typeof ResizeObserver !== 'undefined') {
            var ro = new ResizeObserver(function() {
                resizeChart();
            });
            ro.observe(el);
        }

        const observer = new MutationObserver(function(mutations) {
            mutations.forEach(function(mutation) {
                if (mutation.type === 'attributes' && mutation.attributeName === 'data-theme') {
                    const dark = document.documentElement.getAttribute('data-theme') === 'dark';
                    const tp = getComputedStyle(document.documentElement).getPropertyValue('--text-primary').trim() || (dark ? '#e8e8e8' : '#2c2c2c');
                    const ts = getComputedStyle(document.documentElement).getPropertyValue('--text-secondary').trim() || (dark ? '#b8b8b8' : '#666');
                    const bl = getComputedStyle(document.documentElement).getPropertyValue('--border-light').trim() || (dark ? '#333' : '#f0f0f0');
                    chart.updateOptions({
                        theme: { mode: dark ? 'dark' : 'light' },
                        xaxis: { labels: { style: { colors: ts } } },
                        yaxis: { labels: { style: { colors: ts } } },
                        legend: { labels: { colors: tp } },
                        grid: { borderColor: bl },
                        tooltip: { theme: dark ? 'dark' : 'light' }
                    });
                }
            });
        });
        observer.observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });
    }

    function formatRelative(date) {
        const s = Math.floor((Date.now() - date.getTime()) / 1000);
        if (s < 45) return 'Just now';
        if (s < 3600) return Math.floor(s / 60) + ' min ago';
        if (s < 86400) return Math.floor(s / 3600) + ' hr ago';
        if (s < 172800) return 'Yesterday';
        return Math.floor(s / 86400) + ' days ago';
    }

    document.querySelectorAll('.tm-relative-time').forEach(function(timeEl) {
        const iso = timeEl.getAttribute('datetime');
        if (!iso) return;
        const d = new Date(iso);
        if (isNaN(d.getTime())) return;
        const rel = document.createElement('span');
        rel.className = 'd-block small text-muted';
        rel.textContent = formatRelative(d);
        timeEl.parentNode.appendChild(rel);
    });
});
</script>
{% endblock %}
