{% extends 'admin/_layout.html.twig' %}

{% block title %}Category Details{% endblock %}
{% block admin_title %}Category Details{% endblock %}

{% block admin_content %}
<div class="card shadow-sm p-4">
    <div class="d-flex justify-content-between align-items-start mb-4">
        <h2 class="h4 mb-0">{{ category.name }}</h2>
        <div class="d-flex gap-2">
            <a href="{{ path('app_category_edit', {'id': category.id}) }}" class="btn btn-brand">Edit</a>
            <a href="{{ path('app_category_index') }}" class="btn btn-outline-secondary">Back to List</a>
        </div>
    </div>

    <div class="mb-3">
        <strong>Name:</strong>
        <p class="mb-0">{{ category.name }}</p>
    </div>
    <div class="mb-3">
        <strong>Description:</strong>
        <p class="mb-0">{{ category.description ?: 'No description provided' }}</p>
    </div>
    <div class="mb-3">
        <strong>Created At:</strong>
        <p class="mb-0">{{ category.createdAt ? category.createdAt|date('Y-m-d H:i:s') : 'N/A' }}</p>
    </div>
    {% if category.updatedAt %}
    <div class="mb-3">
        <strong>Updated At:</strong>
        <p class="mb-0">{{ category.updatedAt|date('Y-m-d H:i:s') }}</p>
    </div>
    {% endif %}
</div>
{% endblock %}






