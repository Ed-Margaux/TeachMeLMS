{% extends 'admin/_layout.html.twig' %}

{% block title %}Categories{% endblock %}
{% block admin_title %}Categories{% endblock %}

{% block admin_content %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="h4 mb-0"> </h2>
    <a href="{{ path('app_category_new') }}" class="btn btn-brand">Add New Category</a>
</div>

<div class="card shadow-sm mb-4">
    <div class="card-body">
        <form method="get" class="d-flex gap-2">
            <input type="text" name="search" class="form-control" placeholder="Search categories..." value="{{ search }}">
            <button type="submit" class="btn btn-outline-secondary">Search</button>
            {% if search %}
                <a href="{{ path('app_category_index') }}" class="btn btn-outline-secondary">Clear</a>
            {% endif %}
        </form>
    </div>
</div>

<div class="card shadow-sm">
    <div class="table-responsive">
        <table class="table table-brand align-middle mb-0">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Description</th>
                    <th>Created</th>
                    <th>Updated</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for category in categories %}
                    <tr>
                        <td class="fw-semibold">{{ category.name }}</td>
                        <td>
                            {% if category.description %}
                                {{ category.description|slice(0, 100) }}{% if category.description|length > 100 %}...{% endif %}
                            {% else %}
                                <span class="text-muted">-</span>
                            {% endif %}
                        </td>
                        <td>{{ category.createdAt ? category.createdAt|date('Y-m-d') : '' }}</td>
                        <td>{{ category.updatedAt ? category.updatedAt|date('Y-m-d') : '' }}</td>
                        <td>
                            <div class="d-flex gap-1">
                                <a href="{{ path('app_category_show', {'id': category.id}) }}" class="btn btn-sm btn-outline-primary" title="View">
                                    <i class="bi bi-eye"></i>
                                </a>
                                {% if is_granted('ROLE_ADMIN') or (category.createdBy and category.createdBy.id == app.user.id) %}
                                    <a href="{{ path('app_category_edit', {'id': category.id}) }}" class="btn btn-sm btn-outline-secondary" title="Edit">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <form method="post" action="{{ path('app_category_delete', {'id': category.id}) }}" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this category?');">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ category.id) }}">
                                        <button class="btn btn-sm btn-outline-danger" title="Delete">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                {% endif %}
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr><td colspan="5">No categories found.</td></tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}

