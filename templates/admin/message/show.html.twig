{% extends 'admin/_layout.html.twig' %}

{% block title %}View Message{% endblock %}
{% block admin_title %}View Message{% endblock %}

{% block admin_content %}
<div class="form-container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="h4 mb-0" style="color: #2c2c2c; font-weight: 600; border-bottom: 2px solid #ED64A6; padding-bottom: 12px; flex: 1;">{{ message.subject }}</h2>
        <div class="d-flex gap-2">
            {% if isRecipient %}
                <a href="{{ path('app_message_compose') }}?reply={{ message.sender.id }}" class="btn btn-brand btn-sm">
                    <i class="bi bi-reply me-1"></i>Reply
                </a>
            {% endif %}
            <form method="post" action="{{ path('app_message_delete', {'id': message.id}) }}" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this message?');">
                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ message.id) }}">
                <button class="btn btn-outline-danger btn-sm">
                    <i class="bi bi-trash me-1"></i>Delete
                </button>
            </form>
        </div>
    </div>

    <div class="mb-4">
        <div class="row mb-3">
            <div class="col-md-6">
                <strong>From:</strong> {{ message.sender.fullName }} ({{ message.sender.email }})
            </div>
            <div class="col-md-6">
                <strong>To:</strong> {{ message.recipient.fullName }} ({{ message.recipient.email }})
            </div>
        </div>
        <div class="row mb-3">
            <div class="col-md-6">
                <strong>Date:</strong> {{ message.createdAt ? message.createdAt|date('F d, Y \a\t H:i') : '' }}
            </div>
            {% if message.isRead and message.readAt %}
                <div class="col-md-6">
                    <strong>Read:</strong> {{ message.readAt|date('F d, Y \a\t H:i') }}
                </div>
            {% endif %}
        </div>
    </div>

    <div class="border-top pt-4">
        <div class="message-content" style="white-space: pre-wrap; line-height: 1.6; color: #2c2c2c;">
            {{ message.content }}
        </div>
    </div>

    <div class="d-flex gap-2 mt-4">
        <a href="{{ path('app_message_index') }}" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-2"></i>Back to Inbox
        </a>
        {% if isRecipient %}
            <a href="{{ path('app_message_compose') }}?reply={{ message.sender.id }}" class="btn btn-brand">
                <i class="bi bi-reply me-2"></i>Reply
            </a>
        {% endif %}
    </div>
</div>
{% endblock %}






