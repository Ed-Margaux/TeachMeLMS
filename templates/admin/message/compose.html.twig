{% extends 'admin/_layout.html.twig' %}

{% block title %}Compose Message{% endblock %}
{% block admin_title %}Compose Message{% endblock %}

{% block admin_content %}
<div class="form-container">
    <h2 class="h4 mb-4" style="color: #2c2c2c; font-weight: 600; border-bottom: 2px solid #ED64A6; padding-bottom: 12px; margin-bottom: 2rem;">
        {% if replyTo is defined and replyTo > 0 %}Reply to Message{% else %}Compose New Message{% endif %}
    </h2>
    
    {{ form_start(form, {'attr': {'class': 'needs-validation', 'novalidate': true}}) }}

    <div class="mb-3">
        {{ form_label(form.recipient, 'To', {'class': 'form-label'}) }}
        {{ form_widget(form.recipient, {'attr': {'class': 'form-select'}}) }}
        {{ form_errors(form.recipient) }}
    </div>

    <div class="mb-3">
        {{ form_label(form.subject, 'Subject', {'class': 'form-label'}) }}
        {{ form_widget(form.subject, {'attr': {'class': 'form-control'}}) }}
        {{ form_errors(form.subject) }}
    </div>

    <div class="mb-3">
        {{ form_label(form.content, 'Message', {'class': 'form-label'}) }}
        {{ form_widget(form.content, {'attr': {'class': 'form-control'}}) }}
        {{ form_errors(form.content) }}
    </div>

    <div class="d-flex gap-2 mt-4">
        <button type="submit" class="btn btn-brand">
            <i class="bi bi-send me-2"></i>Send Message
        </button>
        <a href="{{ path('app_message_index') }}" class="btn btn-outline-secondary">Cancel</a>
    </div>

    {{ form_end(form) }}
</div>
{% endblock %}

