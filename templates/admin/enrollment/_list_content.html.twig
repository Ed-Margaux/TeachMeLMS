<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2" data-tm-sync-summary>
    <h2 class="h4 mb-0">Enrollment requests</h2>
    {% if pendingCount > 0 %}
        <span class="badge bg-warning text-dark">{{ pendingCount }} pending</span>
    {% endif %}
</div>
<div class="table-responsive" data-tm-sync-table>
    <table class="table table-brand align-middle mb-0">
        <thead>
            <tr>
                <th>Student</th>
                <th>Course</th>
                <th>Tutor</th>
                <th>Status</th>
                <th>Requested</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for enrollment in enrollments %}
                <tr>
                    <td class="fw-semibold">{{ enrollment.student.fullName }}</td>
                    <td>{{ enrollment.course.title }}</td>
                    <td>{{ enrollment.tutor ? enrollment.tutor.fullName : '—' }}</td>
                    <td>
                        <span class="badge {% if enrollment.status == 'pending' %}bg-warning text-dark{% elseif enrollment.status == 'active' %}bg-success{% elseif enrollment.status == 'rejected' %}bg-danger{% else %}bg-secondary{% endif %}">
                            {{ enrollment.status }}
                        </span>
                    </td>
                    <td>{{ enrollment.requestedAt|date('Y-m-d H:i') }}</td>
                    <td>
                        <a href="{{ path('app_enrollment_show', {id: enrollment.id}) }}" class="btn btn-sm btn-outline-secondary">View</a>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="6" class="text-muted text-center py-4">No enrollment requests yet.</td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
