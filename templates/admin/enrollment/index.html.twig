{% extends 'admin/_layout.html.twig' %}

{% block title %}Enrollments{% endblock %}
{% block admin_title %}Enrollment requests{% endblock %}

{% block admin_content %}
<div class="card shadow-sm mb-4">
    <div class="card-body">
        <form method="get" class="d-flex gap-2 flex-wrap">
            <select name="status" class="form-select" style="max-width: 220px;">
                <option value="">All statuses</option>
                <option value="pending" {% if status == 'pending' %}selected{% endif %}>Pending</option>
                <option value="active" {% if status == 'active' %}selected{% endif %}>Active</option>
                <option value="rejected" {% if status == 'rejected' %}selected{% endif %}>Rejected</option>
                <option value="cancelled" {% if status == 'cancelled' %}selected{% endif %}>Cancelled</option>
                <option value="completed" {% if status == 'completed' %}selected{% endif %}>Completed</option>
            </select>
            <button type="submit" class="btn btn-outline-secondary">Filter</button>
            {% if status %}
                <a href="{{ path('app_enrollment_index') }}" class="btn btn-outline-secondary">Clear</a>
            {% endif %}
        </form>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-body" id="tm-enrollments-live" data-tm-sync-partial-url="{{ path('app_enrollment_index', app.request.query.all|merge({partial: 1})) }}">
        {% include 'admin/enrollment/_list_content.html.twig' %}
    </div>
</div>
{% endblock %}
