{# Standardized Form Base Template #}
{# Usage: {% include 'admin/_form_base.html.twig' with {'form': form, 'cancel_path': 'route_name'} %} #}

<style>
    /* Standardized Form Styles */
    .form-container {
        background: white;
        border-radius: 12px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
        padding: 2rem;
    }
    
    .form-label {
        font-size: 14px;
        font-weight: 500;
        color: #2c2c2c;
        margin-bottom: 8px;
    }
    
    .form-control,
    .form-select {
        border-radius: 8px;
        border: 1px solid #e0e0e0;
        padding: 12px 16px;
        font-size: 16px;
        transition: all 0.2s;
    }
    
    .form-control:focus,
    .form-select:focus {
        border-color: #ED64A6;
        box-shadow: 0 0 0 0.2rem rgba(237, 100, 166, 0.25);
        outline: none;
    }
    
    .form-control::placeholder {
        color: #999;
    }
    
    /* Password inputs - same style as other inputs */
    input[type="password"].form-control,
    input[type="password"] {
        border-radius: 8px;
        border: 1px solid #e0e0e0;
        padding: 12px 16px;
        font-size: 16px;
        width: 100%;
        transition: all 0.2s;
    }
    
    input[type="password"].form-control:focus,
    input[type="password"]:focus {
        border-color: #ED64A6;
        box-shadow: 0 0 0 0.2rem rgba(237, 100, 166, 0.25);
        outline: none;
    }
    
    .form-errors {
        color: #dc3545;
        font-size: 14px;
        margin-top: 4px;
    }
    
    .btn-brand {
        background: linear-gradient(135deg, #C53678, #ED64A6);
        border: none;
        color: white;
        font-weight: 600;
        padding: 12px 24px;
        border-radius: 8px;
        transition: all 0.3s;
    }
    
    .btn-brand:hover {
        background: linear-gradient(135deg, #B02D6B, #D8559A);
        transform: translateY(-1px);
        box-shadow: 0 4px 12px rgba(197, 54, 120, 0.3);
    }
    
    .btn-outline-secondary {
        border: 1px solid #e0e0e0;
        color: #666;
        padding: 12px 24px;
        border-radius: 8px;
        transition: all 0.3s;
    }
    
    .btn-outline-secondary:hover {
        background: #f8f9fa;
        border-color: #ddd;
    }
</style>

<div class="form-container">
    {{ form_start(form, {'attr': {'class': 'needs-validation', 'novalidate': true}}) }}
    
    {% block form_fields %}{% endblock %}
    
    <div class="d-flex gap-2 mt-4">
        <button type="submit" class="btn btn-brand">
            {% block submit_button_text %}Save{% endblock %}
        </button>
        {% if cancel_path is defined %}
        <a href="{{ path(cancel_path) }}" class="btn btn-outline-secondary">Cancel</a>
        {% endif %}
    </div>
    
    {{ form_end(form) }}
</div>

