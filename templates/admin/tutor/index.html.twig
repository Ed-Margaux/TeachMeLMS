{% extends 'admin/_layout.html.twig' %}

{% block title %}Tutors{% endblock %}
{% block admin_title %}Tutors{% endblock %}

{% block admin_content %}
<style>
    .summary-card {
        background: var(--bg-card);
        border-radius: 12px;
        padding: 1.5rem;
        box-shadow: var(--shadow-sm);
        display: flex;
        align-items: center;
        gap: 1rem;
        transition: background-color 0.3s ease;
    }
    
    .summary-card-icon {
        width: 48px;
        height: 48px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 24px;
    }
    
    .summary-card.specialties {
        background: #f5e6d3;
    }
    
    [data-theme="dark"] .summary-card.specialties {
        background: var(--bg-tertiary);
        border: 1px solid var(--border-color);
    }
    
    .summary-card.specialties .summary-card-icon {
        background: rgba(139, 69, 19, 0.1);
        color: #8b4513;
    }
    
    [data-theme="dark"] .summary-card.specialties .summary-card-icon {
        background: rgba(237, 100, 166, 0.2);
        color: var(--pink-primary);
    }
    
    .summary-card.total {
        background: #e3f2fd;
    }
    
    [data-theme="dark"] .summary-card.total {
        background: var(--bg-tertiary);
        border: 1px solid var(--border-color);
    }
    
    .summary-card.total .summary-card-icon {
        background: rgba(33, 150, 243, 0.1);
        color: #2196f3;
    }
    
    [data-theme="dark"] .summary-card.total .summary-card-icon {
        background: rgba(237, 100, 166, 0.2);
        color: var(--pink-primary);
    }
    
    .summary-card-content {
        flex: 1;
    }
    
    .summary-card-label {
        font-size: 13px;
        color: var(--text-secondary);
        font-weight: 500;
        margin-bottom: 4px;
    }
    
    .summary-card-value {
        font-size: 28px;
        font-weight: 700;
        color: var(--text-primary);
    }
    
    .profile-card {
        background: var(--bg-card);
        border-radius: 12px;
        padding: 1.5rem;
        box-shadow: var(--shadow-sm);
        position: relative;
        margin-bottom: 1.5rem;
        transition: background-color 0.3s ease;
    }
    
    .profile-header {
        display: flex;
        align-items: flex-start;
        gap: 1.25rem;
        margin-bottom: 1.5rem;
    }
    
    .profile-image {
        width: 100px;
        height: 100px;
        border-radius: 50%;
        object-fit: cover;
        border: 3px solid var(--border-light);
    }
    
    .profile-image-placeholder {
        width: 100px;
        height: 100px;
        border-radius: 50%;
        background: #f0f0f0;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2.5rem;
        color: #999;
        border: 3px solid #e0e0e0;
    }
    
    .profile-info {
        flex: 1;
    }
    
    .profile-name {
        font-size: 20px;
        font-weight: 700;
        color: var(--text-primary);
        margin-bottom: 4px;
    }
    
    .profile-email {
        font-size: 14px;
        color: var(--text-secondary);
    }
    
    .profile-menu {
        position: absolute;
        top: 1.5rem;
        right: 1.5rem;
    }
    
    .profile-menu-btn {
        background: none;
        border: none;
        color: var(--text-secondary);
        font-size: 18px;
        cursor: pointer;
        padding: 4px 8px;
        border-radius: 4px;
        transition: all 0.2s;
    }
    
    .profile-menu-btn:hover {
        background: var(--bg-hover);
        color: var(--text-primary);
    }
    
    .profile-details {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
        margin-bottom: 1.5rem;
        padding-top: 1.5rem;
        border-top: 1px solid var(--border-light);
    }
    
    .profile-detail-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }
    
    .profile-detail-label {
        font-size: 14px;
        color: var(--text-secondary);
        font-weight: 500;
    }
    
    .profile-detail-value {
        font-size: 14px;
        color: var(--text-primary);
        font-weight: 600;
        text-align: right;
    }
    
    .profile-footer {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding-top: 1rem;
        border-top: 1px solid var(--border-light);
    }
    
    .status-badge {
        padding: 6px 16px;
        border-radius: 20px;
        font-size: 13px;
        font-weight: 600;
        background: #d4edda;
        color: #155724;
    }
    
    .profile-actions {
        display: flex;
        gap: 8px;
    }
    
    .action-btn {
        width: 36px;
        height: 36px;
        border-radius: 8px;
        border: none;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 16px;
        cursor: pointer;
        transition: all 0.2s;
        text-decoration: none;
    }
    
    .action-btn.view {
        background: #2196f3;
        color: white;
    }
    
    .action-btn.view:hover {
        background: #1976d2;
        transform: translateY(-2px);
    }
    
    .action-btn.edit {
        background: #ff9800;
        color: white;
    }
    
    .action-btn.edit:hover {
        background: #f57c00;
        transform: translateY(-2px);
    }
    
    .action-btn[style*="background: #dc3545"] {
        background: #dc3545 !important;
        color: white !important;
    }
    
    .action-btn[style*="background: #dc3545"]:hover {
        background: #c82333 !important;
        transform: translateY(-2px);
    }
    
    .filter-section {
        background: var(--bg-secondary);
        padding: 1rem;
        border-radius: 8px;
        margin-bottom: 1.5rem;
        transition: background-color 0.3s ease;
    }
    
    .filter-section .form-select {
        background: var(--bg-input);
    }
</style>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="h4 mb-0"> </h2>
    <a href="{{ path('app_tutor_new') }}" class="btn btn-brand">Add New Tutor</a>
</div>

<!-- Summary Cards -->
<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="summary-card specialties">
            <div class="summary-card-icon">
                <i class="bi bi-mortarboard-fill"></i>
            </div>
            <div class="summary-card-content">
                <div class="summary-card-label">Specialties</div>
                <div class="summary-card-value">{{ totalSpecialties }}</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="summary-card total">
            <div class="summary-card-icon">
                <i class="bi bi-people-fill"></i>
            </div>
            <div class="summary-card-content">
                <div class="summary-card-label">Total Tutors</div>
                <div class="summary-card-value">{{ totalTutors }}</div>
            </div>
        </div>
    </div>
</div>

<!-- Filters -->
<div class="filter-section">
    <form method="get" class="row g-2 align-items-end">
        <div class="col-md-4">
            <label class="form-label small">Search</label>
            <input type="text" name="search" class="form-control" placeholder="Search tutors..." value="{{ search }}">
        </div>
        <div class="col-md-3">
            <label class="form-label small">Status</label>
            <select name="status" class="form-select">
                <option value="">All Status</option>
                <option value="active">Active</option>
                <option value="inactive">Inactive</option>
            </select>
        </div>
        <div class="col-md-3">
            <label class="form-label small">Specialty</label>
            <select name="specialty" class="form-select">
                <option value="">All Specialties</option>
                {% for specialty in specialties|sort %}
                    <option value="{{ specialty }}">{{ specialty }}</option>
                {% endfor %}
            </select>
        </div>
        <div class="col-md-2">
            <button type="submit" class="btn btn-brand w-100">Filter</button>
        </div>
    </form>
</div>

<!-- Profile Cards -->
{% if tutors|length > 0 %}
    <div class="row">
        {% for tutor in tutors %}
            <div class="col-md-6 col-lg-4">
                <div class="profile-card">
                    <div class="profile-header">
                        {% if tutor.image %}
                            <img src="{{ asset('uploads/tutors/' ~ tutor.image) }}" alt="{{ tutor.fullName }}" class="profile-image">
                        {% else %}
                            <div class="profile-image-placeholder">
                                <i class="bi bi-person"></i>
                            </div>
                        {% endif %}
                        <div class="profile-info">
                            <div class="profile-name">{{ tutor.fullName }}</div>
                            <div class="profile-email">{{ tutor.email }}</div>
                        </div>
                        <div class="profile-menu">
                            <button class="profile-menu-btn" type="button" data-bs-toggle="dropdown">
                                <i class="bi bi-three-dots-vertical"></i>
                            </button>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" href="{{ path('app_tutor_show', {'id': tutor.id}) }}"><i class="bi bi-eye me-2"></i>View</a></li>
                                {% if is_granted('ROLE_ADMIN') or (tutor.createdBy and tutor.createdBy.id == app.user.id) %}
                                    <li><a class="dropdown-item" href="{{ path('app_tutor_edit', {'id': tutor.id}) }}"><i class="bi bi-pencil me-2"></i>Edit</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <form method="post" action="{{ path('app_tutor_delete', {'id': tutor.id}) }}" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this tutor?');">
                                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ tutor.id) }}">
                                            <button type="submit" class="dropdown-item text-danger"><i class="bi bi-trash me-2"></i>Delete</button>
                                        </form>
                                    </li>
                                {% endif %}
                            </ul>
                        </div>
                    </div>
                    
                    <div class="profile-details">
                        <div class="profile-detail-item">
                            <span class="profile-detail-label">Specialty:</span>
                            <span class="profile-detail-value">{{ tutor.specialty ?? '-' }}</span>
                        </div>
                        <div class="profile-detail-item">
                            <span class="profile-detail-label">Phone:</span>
                            <span class="profile-detail-value">{{ tutor.phone ?? '-' }}</span>
                        </div>
                        <div class="profile-detail-item" style="grid-column: 1 / -1;">
                            <span class="profile-detail-label">Joined:</span>
                            <span class="profile-detail-value">{{ tutor.createdAt ? tutor.createdAt|date('M d, Y') : '-' }}</span>
                        </div>
                    </div>
                    
                    <div class="profile-footer">
                        <span class="status-badge">Active</span>
                        <div class="profile-actions">
                            <a href="{{ path('app_tutor_show', {'id': tutor.id}) }}" class="action-btn view" title="View">
                                <i class="bi bi-eye"></i>
                            </a>
                            {% if is_granted('ROLE_ADMIN') or (tutor.createdBy and tutor.createdBy.id == app.user.id) %}
                                <a href="{{ path('app_tutor_edit', {'id': tutor.id}) }}" class="action-btn edit" title="Edit">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <form method="post" action="{{ path('app_tutor_delete', {'id': tutor.id}) }}" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this tutor?');">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ tutor.id) }}">
                                    <button type="submit" class="action-btn" style="background: #dc3545; color: white;" title="Delete">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>
        {% endfor %}
    </div>
{% else %}
    <div class="card shadow-sm">
        <div class="card-body text-center py-5">
            <i class="bi bi-person-x text-muted" style="font-size: 3rem;"></i>
            <p class="text-muted mt-3">No tutors found.</p>
        </div>
    </div>
{% endif %}
{% endblock %}
