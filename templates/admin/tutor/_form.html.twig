{{ form_start(form, {'attr': {'class': 'needs-validation', 'novalidate': true}}) }}

<div class="row mb-3">
    <div class="col-md-6">
        {{ form_label(form.firstName, 'First Name', {'class': 'form-label'}) }}
        {{ form_widget(form.firstName, {'attr': {'class': 'form-control'}}) }}
        {{ form_errors(form.firstName) }}
    </div>
    <div class="col-md-6">
        {{ form_label(form.lastName, 'Last Name', {'class': 'form-label'}) }}
        {{ form_widget(form.lastName, {'attr': {'class': 'form-control'}}) }}
        {{ form_errors(form.lastName) }}
    </div>
</div>

<div class="row mb-3">
    <div class="col-md-6">
        {{ form_label(form.email, 'Email', {'class': 'form-label'}) }}
        {{ form_widget(form.email, {'attr': {'class': 'form-control'}}) }}
        {{ form_errors(form.email) }}
    </div>
    <div class="col-md-6">
        {{ form_label(form.phone, 'Phone', {'class': 'form-label'}) }}
        {{ form_widget(form.phone, {'attr': {'class': 'form-control'}}) }}
        {{ form_errors(form.phone) }}
    </div>
</div>

<div class="mb-3">
    {{ form_label(form.specialty, 'Specialty', {'class': 'form-label'}) }}
    {{ form_widget(form.specialty, {'attr': {'class': 'form-select'}}) }}
    {{ form_errors(form.specialty) }}
</div>

<div class="mb-3">
    {{ form_label(form.imageFile, 'Profile Picture', {'class': 'form-label'}) }}
    {{ form_widget(form.imageFile, {'attr': {'class': 'form-control'}}) }}
    {{ form_errors(form.imageFile) }}
    {% if tutor.image %}
        <div class="mt-2">
            <small class="text-muted">Current image: {{ tutor.image }}</small>
            <img src="{{ asset('uploads/tutors/' ~ tutor.image) }}" alt="Tutor image" class="img-thumbnail mt-2" style="max-width: 200px;">
        </div>
    {% endif %}
</div>

    <div class="d-flex gap-2 mt-4">
        <button type="submit" class="btn btn-brand">Save</button>
        <a href="{{ path('app_tutor_index') }}" class="btn btn-outline-secondary">Cancel</a>
    </div>

    {{ form_end(form) }}

