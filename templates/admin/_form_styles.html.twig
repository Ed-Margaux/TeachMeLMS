{# Standardized Form Styles - Include this in all form templates #}
<style>
    .form-container {
        background: white;
        border-radius: 12px;
        padding: 2rem;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    }
    
    .form-label {
        font-size: 14px;
        font-weight: 500;
        color: #2c2c2c;
        margin-bottom: 8px;
        display: block;
    }
    
    .form-control,
    .form-select {
        border-radius: 8px;
        border: 1px solid #e0e0e0;
        padding: 12px 16px;
        font-size: 16px;
        width: 100%;
        transition: all 0.2s ease;
    }
    
    .form-control:focus,
    .form-select:focus {
        border-color: #ED64A6;
        box-shadow: 0 0 0 0.2rem rgba(237, 100, 166, 0.25);
        outline: none;
    }
    
    .form-control[type="password"] {
        border-radius: 8px;
        border: 1px solid #e0e0e0;
        padding: 12px 16px;
        font-size: 16px;
    }
    
    .form-control[type="file"] {
        padding: 8px;
    }
    
    .form-text {
        font-size: 13px;
        color: #666;
        margin-top: 4px;
    }
    
    .invalid-feedback {
        display: block;
        color: #dc3545;
        font-size: 13px;
        margin-top: 4px;
    }
    
    .btn-brand {
        background: linear-gradient(135deg, #C53678, #ED64A6);
        border: none;
        color: white;
        font-weight: 600;
        padding: 12px 24px;
        border-radius: 8px;
        font-size: 16px;
        transition: all 0.3s ease;
    }
    
    .btn-brand:hover {
        background: linear-gradient(135deg, #B02D6B, #D8559A);
        transform: translateY(-1px);
        box-shadow: 0 4px 12px rgba(197, 54, 120, 0.3);
    }
    
    .btn-outline-secondary {
        border: 1px solid #e0e0e0;
        color: #666;
        padding: 12px 24px;
        border-radius: 8px;
        font-size: 16px;
        background: white;
        transition: all 0.2s ease;
    }
    
    .btn-outline-secondary:hover {
        background: #f8f9fa;
        border-color: #d0d0d0;
    }
    
    .mb-3 {
        margin-bottom: 1.5rem;
    }
    
    .mb-4 {
        margin-bottom: 2rem;
    }
</style>






