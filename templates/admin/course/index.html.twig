{% extends 'admin/_layout.html.twig' %}

{% block title %}Courses{% endblock %}
{% block admin_title %}Courses{% endblock %}

{% block admin_content %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="h4 mb-0"> </h2>
    <a href="{{ path('app_course_new') }}" class="btn btn-brand">Add New Course</a>
</div>

<div class="card shadow-sm mb-4">
    <div class="card-body">
        <form method="get" class="d-flex gap-2">
            <input type="text" name="search" class="form-control" placeholder="Search courses..." value="{{ search }}">
            <button type="submit" class="btn btn-outline-secondary">Search</button>
            {% if search %}
                <a href="{{ path('app_course_index') }}" class="btn btn-outline-secondary">Clear</a>
            {% endif %}
        </form>
    </div>
</div>

<div class="card shadow-sm">
    <div class="table-responsive">
        <table class="table table-brand align-middle mb-0">
            <thead>
                <tr>
                    <th>Image</th>
                    <th>Title</th>
                    <th>Level</th>
                    <th>Slug</th>
                    <th>Created By</th>
                    <th>Created</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for course in courses %}
                    <tr>
                        <td>
                            {% if course.image %}
                                <img src="{{ asset('uploads/courses/' ~ course.image) }}" alt="{{ course.title }}" class="img-thumbnail" style="max-width: 60px; max-height: 60px;">
                            {% else %}
                                <div class="d-flex align-items-center justify-content-center" style="width: 60px; height: 60px; border-radius: 4px; background: var(--bg-secondary);">
                                    <i class="bi bi-image text-muted"></i>
                                </div>
                            {% endif %}
                        </td>
                        <td>
                            <div class="fw-semibold">{{ course.title }}</div>
                            {% if course.description %}
                                <small class="text-muted">{{ course.description|slice(0, 50) }}{% if course.description|length > 50 %}...{% endif %}</small>
                            {% endif %}
                        </td>
                        <td>
                            {% if course.level %}
                                <span class="badge bg-info">{{ course.level }}</span>
                            {% else %}
                                <span class="text-muted">-</span>
                            {% endif %}
                        </td>
                        <td><code class="small">{{ course.slug }}</code></td>
                        <td>{{ course.createdBy ? course.createdBy.fullName : 'N/A' }}</td>
                        <td>{{ course.createdAt ? course.createdAt|date('Y-m-d') : '' }}</td>
                        <td>
                            <div class="d-flex gap-1">
                                <a href="{{ path('app_course_show', {'id': course.id}) }}" class="btn btn-sm btn-outline-primary" title="View">
                                    <i class="bi bi-eye"></i>
                                </a>
                                {% if is_granted('ROLE_ADMIN') or (course.createdBy and course.createdBy.id == app.user.id) %}
                                    <a href="{{ path('app_course_edit', {'id': course.id}) }}" class="btn btn-sm btn-outline-secondary" title="Edit">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <form method="post" action="{{ path('app_course_delete', {'id': course.id}) }}" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this course?');">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ course.id) }}">
                                        <button class="btn btn-sm btn-outline-danger" title="Delete">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                {% endif %}
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr><td colspan="7">No courses found.</td></tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}

