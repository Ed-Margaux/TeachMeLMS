{% extends 'base.html.twig' %}

{% block stylesheets %}
    {{ parent() }}
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Lato:ital,wght@0,400;0,600;0,700;1,400&family=Merriweather:wght@700;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="{{ asset('styles/variables.css') }}">
    <link rel="stylesheet" href="{{ asset('styles/forms.css') }}">
    <link rel="stylesheet" href="{{ asset('styles/components.css') }}">
    <link rel="stylesheet" href="{{ asset('styles/layout.css') }}">
    <link rel="stylesheet" href="{{ asset('styles/utilities.css') }}">
    <link rel="stylesheet" href="{{ asset('styles/dark-mode.css') }}">
    <style>
        /* CSS Variables for Light Mode (Default) */
        :root {
            --bg-primary: #ffffff;
            --bg-secondary: #f8f9fa;
            --bg-tertiary: #ffffff;
            --bg-hover: #f8f9fa;
            --bg-card: #ffffff;
            --bg-sidebar: #ffffff;
            --bg-topbar: #ffffff;
            --bg-form: #ffffff;
            --bg-input: #ffffff;
            --bg-table-header: linear-gradient(135deg, #f8f9fa, #ffffff);
            
            --text-primary: #2c2c2c;
            --text-secondary: #666;
            --text-muted: #999;
            --text-light: #6c757d;
            
            --border-color: #e0e0e0;
            --border-light: #f0f0f0;
            --border-hover: #d0d0d0;
            
            --pink-primary: #ED64A6;
            --pink-secondary: #C53678;
            --pink-dark: #B02D6B;
            --pink-light: #fff5f9;
            --pink-hover: rgba(237, 100, 166, 0.15);
            --pink-shadow: rgba(237, 100, 166, 0.3);
            
            --shadow-sm: 0 2px 8px rgba(0, 0, 0, 0.08);
            --shadow-md: 0 4px 16px rgba(0, 0, 0, 0.12);
            --shadow-lg: 0 2px 12px rgba(0, 0, 0, 0.08);
        }
        
        /* CSS Variables for Dark Mode */
        [data-theme="dark"] {
            --bg-primary: #1a1a1a;
            --bg-secondary: #242424;
            --bg-tertiary: #2a2a2a;
            --bg-hover: #2f2f2f;
            --bg-card: #242424;
            --bg-sidebar: #1e1e1e;
            --bg-topbar: #242424;
            --bg-form: #2a2a2a;
            --bg-input: #2a2a2a;
            --bg-table-header: linear-gradient(135deg, #2a2a2a, #242424);
            
            --text-primary: #e8e8e8;
            --text-secondary: #b8b8b8;
            --text-muted: #888;
            --text-light: #999;
            
            --border-color: #3a3a3a;
            --border-light: #333;
            --border-hover: #4a4a4a;
            
            --pink-primary: #ED64A6;
            --pink-secondary: #C53678;
            --pink-dark: #B02D6B;
            --pink-light: #2a1f24;
            --pink-hover: rgba(237, 100, 166, 0.2);
            --pink-shadow: rgba(237, 100, 166, 0.4);
            
            --shadow-sm: 0 2px 8px rgba(0, 0, 0, 0.3);
            --shadow-md: 0 4px 16px rgba(0, 0, 0, 0.4);
            --shadow-lg: 0 2px 12px rgba(0, 0, 0, 0.3);
        }
        
        /* Dark Mode Toggle Button */
        .dark-mode-toggle {
            background: var(--bg-card);
            border: 1.5px solid var(--border-color);
            color: var(--text-primary);
            width: 40px;
            height: 40px;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: all 0.3s ease;
            font-size: 1.2rem;
        }
        
        .dark-mode-toggle:hover {
            background: var(--bg-hover);
            border-color: var(--pink-primary);
            color: var(--pink-primary);
            transform: translateY(-2px);
            box-shadow: 0 2px 8px var(--pink-shadow);
        }
        
        /* Apply theme colors */
        body {
            background: var(--bg-secondary);
            color: var(--text-primary);
            transition: background-color 0.3s ease, color 0.3s ease;
        }
        
        .tm-admin-app {
            font-family: "Lato", system-ui, -apple-system, sans-serif;
            --sidebar-motion-duration: 0.52s;
            --sidebar-motion-ease: cubic-bezier(0.33, 1, 0.68, 1);
            --sidebar-shadow-duration: 0.45s;
        }
        @media (prefers-reduced-motion: reduce) {
            .tm-admin-app {
                --sidebar-motion-duration: 0s;
                --sidebar-shadow-duration: 0s;
            }
        }
        .tm-admin-app h1,
        .tm-admin-app h2,
        .tm-admin-app h3,
        .tm-admin-app .h1,
        .tm-admin-app .h2 {
            font-family: "Merriweather", Georgia, serif;
        }
        
        /* Sidebar: Teach Me brand — collapsed to icons; expands on hover */
        .sidebar {
            background: #C53678;
            border-right: 1px solid transparent;
            height: 100vh;
            width: 76px;
            position: fixed;
            left: 0;
            top: 0;
            z-index: 100;
            display: flex;
            flex-direction: column;
            box-shadow: 4px 0 28px rgba(197, 54, 120, 0.28);
            transition:
                width var(--sidebar-motion-duration) var(--sidebar-motion-ease),
                box-shadow var(--sidebar-shadow-duration) var(--sidebar-motion-ease),
                background var(--sidebar-motion-duration) var(--sidebar-motion-ease),
                border-color var(--sidebar-motion-duration) var(--sidebar-motion-ease);
            overflow: hidden;
        }
        /* Light panel on hover so tmMainlogo (pink/coral on dark) stays legible on a soft tint */
        .sidebar:hover {
            width: 260px;
            box-shadow: 8px 0 36px rgba(45, 18, 32, 0.12);
            background: linear-gradient(168deg, #ffffff 0%, #fff9fb 38%, #fdeef4 100%);
            border-right-color: rgba(197, 54, 120, 0.14);
        }
        [data-theme="dark"] .sidebar {
            background: linear-gradient(180deg, #9e2f62 0%, #6e2145 100%);
            box-shadow: 4px 0 24px rgba(0, 0, 0, 0.45);
        }
        [data-theme="dark"] .sidebar:hover {
            background: linear-gradient(168deg, #2a1822 0%, #3d2434 48%, #4d2d42 100%);
            border-right-color: rgba(237, 100, 166, 0.22);
            box-shadow: 8px 0 40px rgba(0, 0, 0, 0.35);
        }
        /* Brand row: tmicon (always); tmMainlogo when expanded */
        .sidebar-brand {
            margin-bottom: 1rem;
            padding: 24px 8px 0;
            flex-shrink: 0;
        }
        .sidebar-brand-hit {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0;
            text-decoration: none;
            color: inherit;
            outline: none;
            transition:
                gap var(--sidebar-motion-duration) var(--sidebar-motion-ease),
                justify-content var(--sidebar-motion-duration) var(--sidebar-motion-ease);
        }
        .sidebar:hover .sidebar-brand-hit {
            justify-content: flex-start;
            gap: 10px;
        }
        .sidebar-brand-hit:focus-visible {
            border-radius: 12px;
            box-shadow: 0 0 0 2px #fff, 0 0 0 4px #C53678;
        }
        .sidebar:hover .sidebar-brand-hit:focus-visible {
            box-shadow: 0 0 0 2px #C53678, 0 0 0 4px rgba(237, 100, 166, 0.5);
        }
        /* tmicon.png: no extra frame, background, or radius — asset is used as-is */
        .sidebar-brand-icon-img {
            flex-shrink: 0;
            display: block;
            width: 48px;
            height: auto;
        }
        .sidebar-brand-wordmark {
            flex: 1;
            min-width: 0;
            max-width: 0;
            opacity: 0;
            overflow: hidden;
            transform: translate3d(-4px, 0, 0);
            transition:
                max-width var(--sidebar-motion-duration) var(--sidebar-motion-ease),
                opacity calc(var(--sidebar-motion-duration) * 0.88) var(--sidebar-motion-ease),
                transform var(--sidebar-motion-duration) var(--sidebar-motion-ease);
        }
        .sidebar:hover .sidebar-brand-wordmark {
            max-width: 200px;
            opacity: 1;
            transform: translate3d(0, 0, 0);
            transition-delay: 0.03s;
        }
        .sidebar-brand-wordmark-img {
            height: 36px;
            width: auto;
            max-width: 178px;
            display: block;
            object-fit: contain;
            object-position: left center;
        }
        .sidebar nav {
            flex: 1;
            overflow-y: auto;
            overflow-x: hidden;
            padding: 0 10px 16px 10px;
        }
        .sidebar nav::-webkit-scrollbar {
            width: 6px;
        }
        .sidebar nav::-webkit-scrollbar-track {
            background: rgba(255, 255, 255, 0.06);
            border-radius: 3px;
        }
        .sidebar nav::-webkit-scrollbar-thumb {
            background: rgba(255, 255, 255, 0.22);
            border-radius: 3px;
        }
        .sidebar nav::-webkit-scrollbar-thumb:hover {
            background: rgba(255, 255, 255, 0.35);
        }
        .sidebar:hover nav::-webkit-scrollbar-track {
            background: rgba(197, 54, 120, 0.06);
        }
        .sidebar:hover nav::-webkit-scrollbar-thumb {
            background: rgba(197, 54, 120, 0.22);
        }
        .sidebar:hover nav::-webkit-scrollbar-thumb:hover {
            background: rgba(197, 54, 120, 0.38);
        }
        [data-theme="dark"] .sidebar:hover nav::-webkit-scrollbar-track {
            background: rgba(255, 255, 255, 0.04);
        }
        [data-theme="dark"] .sidebar:hover nav::-webkit-scrollbar-thumb {
            background: rgba(237, 100, 166, 0.25);
        }
        .sidebar .nav-link {
            color: rgba(255, 255, 255, 0.94);
            font-weight: 600;
            border-radius: 10px;
            margin-bottom: 6px;
            padding: 11px 12px;
            display: flex;
            align-items: center;
            gap: 0;
            transition:
                background 0.22s ease,
                color 0.22s ease,
                box-shadow 0.22s ease,
                gap var(--sidebar-motion-duration) var(--sidebar-motion-ease);
            justify-content: center;
            white-space: nowrap;
        }
        .sidebar:hover .nav-link {
            justify-content: flex-start;
            gap: 12px;
        }
        .sidebar .nav-link i {
            font-size: 1.2rem;
            flex-shrink: 0;
            width: 1.5rem;
            text-align: center;
        }
        .sidebar .nav-link span {
            display: inline-block;
            max-width: 0;
            opacity: 0;
            overflow: hidden;
            transform: translate3d(-6px, 0, 0);
            transition:
                max-width var(--sidebar-motion-duration) var(--sidebar-motion-ease),
                opacity calc(var(--sidebar-motion-duration) * 0.85) var(--sidebar-motion-ease),
                transform var(--sidebar-motion-duration) var(--sidebar-motion-ease);
            transition-delay: 0s, 0s, 0s;
            vertical-align: middle;
        }
        .sidebar:hover .nav-link span {
            max-width: 220px;
            opacity: 1;
            transform: translate3d(0, 0, 0);
            transition-delay: 0s, 0.04s, 0.02s;
        }
        .sidebar .nav-link:hover {
            background: rgba(255, 255, 255, 0.12);
            color: #fff;
            transform: none;
            box-shadow: none;
        }
        .sidebar .nav-link.active {
            background: rgba(255, 255, 255, 0.16);
            color: #fff;
            box-shadow: inset 3px 0 0 #ED64A6;
            transform: none;
        }
        /* Expanded (light) rail: dark text + brand-colored icons */
        .sidebar:hover .nav-link {
            color: #4a3540;
        }
        .sidebar:hover .nav-link i {
            color: #C53678;
        }
        .sidebar:hover .nav-link:hover {
            background: rgba(197, 54, 120, 0.09);
            color: #8f1f56;
        }
        .sidebar:hover .nav-link:hover i {
            color: #C53678;
        }
        .sidebar:hover .nav-link.active {
            background: rgba(197, 54, 120, 0.11);
            color: #6d1844;
            box-shadow: inset 3px 0 0 #C53678;
        }
        .sidebar:hover .nav-link.active i {
            color: #C53678;
        }
        [data-theme="dark"] .sidebar:hover .nav-link {
            color: rgba(255, 255, 255, 0.94);
        }
        [data-theme="dark"] .sidebar:hover .nav-link i {
            color: #ED64A6;
        }
        [data-theme="dark"] .sidebar:hover .nav-link:hover {
            background: rgba(237, 100, 166, 0.12);
            color: #fff;
        }
        [data-theme="dark"] .sidebar:hover .nav-link:hover i {
            color: #ffb3d4;
        }
        [data-theme="dark"] .sidebar:hover .nav-link.active {
            background: rgba(237, 100, 166, 0.16);
            color: #fff;
            box-shadow: inset 3px 0 0 #ED64A6;
        }
        [data-theme="dark"] .sidebar:hover .nav-link.active i {
            color: #ffb3d4;
        }
        .admin-main {
            margin-left: 76px;
            min-height: 100vh;
            background: var(--bg-secondary);
            transition:
                margin-left var(--sidebar-motion-duration) var(--sidebar-motion-ease),
                background-color 0.3s ease;
        }
        .sidebar:hover ~ .admin-main {
            margin-left: 260px;
        }
        .admin-topbar {
            background: var(--bg-topbar);
            border-bottom: 1px solid var(--border-color);
            padding: 18px 32px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
            flex-wrap: nowrap;
            box-shadow: var(--shadow-sm);
            transition: background-color 0.3s ease, border-color 0.3s ease;
        }
        .admin-mobile-nav-toggle {
            display: none;
            align-items: center;
            justify-content: center;
            width: 44px;
            height: 44px;
            padding: 0;
            flex-shrink: 0;
            border: 1.5px solid var(--border-color);
            border-radius: 10px;
            background: var(--bg-card);
            color: var(--text-primary);
            cursor: pointer;
            transition: color 0.2s, border-color 0.2s, background 0.2s;
        }
        .admin-mobile-nav-toggle:hover {
            border-color: rgba(197, 54, 120, 0.45);
            color: #C53678;
            background: rgba(197, 54, 120, 0.06);
        }
        .admin-mobile-nav-toggle i {
            font-size: 1.35rem;
            line-height: 1;
        }
        .admin-sidebar-backdrop {
            display: none;
            position: fixed;
            inset: 0;
            z-index: 1050;
            background: rgba(18, 10, 14, 0.48);
            backdrop-filter: blur(3px);
            -webkit-backdrop-filter: blur(3px);
        }
        .admin-sidebar-backdrop.is-visible {
            display: block;
        }
        body.admin-mobile-nav-open {
            overflow: hidden;
        }
        .admin-topbar .search-box {
            width: 320px;
            position: relative;
        }
        .admin-topbar .search-box input {
            width: 100%;
            border-radius: 20px;
            border: 1.5px solid var(--border-color);
            padding: 10px 18px 10px 42px;
            font-size: 14px;
            transition: all 0.3s ease;
            background: var(--bg-input);
            color: var(--text-primary);
        }
        
        .admin-topbar .search-box input:focus {
            border-color: var(--pink-primary);
            box-shadow: 0 0 0 0.2rem var(--pink-hover);
            outline: none;
        }
        
        .admin-topbar .search-box input::placeholder {
            color: var(--text-muted);
        }
        
        .admin-topbar .search-box i {
            position: absolute;
            left: 14px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--text-muted);
            pointer-events: none;
        }
        .tm-topbar-notify {
            width: 40px;
            height: 40px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--text-secondary);
            background: var(--bg-card);
            border: 1.5px solid var(--border-color);
            text-decoration: none;
            transition: color 0.2s, border-color 0.2s, background 0.2s;
        }
        .tm-topbar-notify:hover {
            color: #C53678;
            border-color: rgba(197, 54, 120, 0.45);
            background: rgba(197, 54, 120, 0.06);
        }
        .search-dropdown {
            position: absolute;
            top: calc(100% + 8px);
            left: 0;
            right: 0;
            background: var(--bg-card);
            border: 1px solid var(--border-color);
            border-radius: 12px;
            box-shadow: var(--shadow-lg);
            max-height: 400px;
            overflow-y: auto;
            z-index: 1000;
            display: none;
        }
        .search-dropdown.show {
            display: block;
        }
        .search-result-item {
            padding: 12px 16px;
            cursor: pointer;
            transition: all 0.2s ease;
            border-bottom: 1px solid var(--border-light);
            display: flex;
            align-items: center;
            gap: 12px;
        }
        .search-result-item:last-child {
            border-bottom: none;
        }
        .search-result-item:hover {
            background: var(--bg-hover);
        }
        .search-result-item.active {
            background: var(--bg-hover);
        }
        .search-result-icon {
            width: 32px;
            height: 32px;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: var(--bg-tertiary);
            color: var(--pink-primary);
            font-size: 16px;
            flex-shrink: 0;
        }
        .search-result-content {
            flex: 1;
            min-width: 0;
        }
        .search-result-title {
            font-weight: 600;
            color: var(--text-primary);
            font-size: 14px;
            margin-bottom: 2px;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }
        .search-result-subtitle {
            font-size: 12px;
            color: var(--text-secondary);
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }
        .search-result-type {
            font-size: 10px;
            text-transform: uppercase;
            color: var(--pink-primary);
            font-weight: 600;
            letter-spacing: 0.5px;
        }
        .search-no-results {
            padding: 20px;
            text-align: center;
            color: var(--text-muted);
            font-size: 14px;
        }
        .admin-topbar .user-avatar {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background: var(--pink-primary);
            color: #fff;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: bold;
            font-size: 1.2rem;
            cursor: pointer;
            transition: all 0.3s ease;
        }
        .admin-topbar .user-avatar:hover {
            transform: scale(1.05);
            box-shadow: 0 2px 8px rgba(237, 100, 166, 0.3);
        }
        .user-dropdown-menu {
            background: var(--bg-card);
            border: 1px solid var(--border-color);
            border-radius: 8px;
            box-shadow: var(--shadow-lg);
            padding: 8px 0;
            min-width: 200px;
            margin-top: 8px;
        }
        .user-dropdown-menu .dropdown-item {
            padding: 10px 20px;
            color: var(--text-primary);
            transition: all 0.2s ease;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .user-dropdown-menu .dropdown-item:hover {
            background: var(--bg-hover);
            color: var(--pink-primary);
        }
        .user-dropdown-menu .dropdown-item i {
            font-size: 1.1rem;
            width: 20px;
        }
        .user-dropdown-menu .dropdown-divider {
            border-color: var(--border-light);
            margin: 4px 0;
        }
        @media (max-width: 900px) {
            .sidebar { width: 64px; }
            .sidebar:hover { width: 240px; z-index: 200; }
            .sidebar-brand-icon-img { width: 44px; }
            .sidebar-brand-wordmark-img { max-width: 150px; height: 32px; }
            .admin-main { margin-left: 64px; }
            .sidebar:hover ~ .admin-main { margin-left: 240px; }
            .admin-topbar .search-box { width: min(100%, 160px); }
        }

        /* Mobile: off-canvas nav + hamburger (≤768px) */
        @media (max-width: 768px) {
            .admin-mobile-nav-toggle {
                display: inline-flex;
            }
            .admin-main {
                margin-left: 0 !important;
            }
            .sidebar:hover ~ .admin-main {
                margin-left: 0 !important;
            }
            .admin-topbar {
                padding: 12px 14px;
                flex-wrap: wrap;
                row-gap: 10px;
            }
            .admin-topbar .search-box {
                flex: 1 1 140px;
                width: auto !important;
                max-width: none;
                min-width: 0;
                order: 2;
            }
            .admin-mobile-nav-toggle {
                order: 1;
            }
            .admin-topbar .admin-topbar-actions {
                order: 3;
                margin-left: auto;
                flex-wrap: wrap;
                justify-content: flex-end;
                gap: 0.5rem !important;
            }
            .admin-topbar .admin-topbar-profile-text {
                display: none !important;
            }
            .sidebar {
                width: min(300px, 88vw) !important;
                max-width: 100vw;
                z-index: 1060;
                transform: translate3d(-100%, 0, 0);
                transition: transform 0.34s cubic-bezier(0.33, 1, 0.68, 1), background 0.25s ease, box-shadow 0.25s ease;
                box-shadow: 8px 0 32px rgba(0, 0, 0, 0.2);
            }
            .sidebar:not(.is-open):hover {
                width: min(300px, 88vw) !important;
                transform: translate3d(-100%, 0, 0);
                background: #C53678;
                border-right-color: transparent;
            }
            [data-theme="dark"] .sidebar:not(.is-open):hover {
                background: linear-gradient(180deg, #9e2f62 0%, #6e2145 100%);
            }
            .sidebar.is-open {
                transform: translate3d(0, 0, 0);
                background: linear-gradient(168deg, #ffffff 0%, #fff9fb 38%, #fdeef4 100%);
                border-right-color: rgba(197, 54, 120, 0.14);
            }
            [data-theme="dark"] .sidebar.is-open {
                background: linear-gradient(168deg, #2a1822 0%, #3d2434 48%, #4d2d42 100%);
                border-right-color: rgba(237, 100, 166, 0.22);
            }
            .sidebar.is-open .sidebar-brand-hit {
                justify-content: flex-start;
                gap: 10px;
            }
            .sidebar.is-open .sidebar-brand-wordmark {
                max-width: 200px;
                opacity: 1;
                transform: translate3d(0, 0, 0);
            }
            .sidebar.is-open .nav-link {
                justify-content: flex-start;
                gap: 12px;
            }
            .sidebar.is-open .nav-link span {
                max-width: 220px;
                opacity: 1;
                transform: translate3d(0, 0, 0);
            }
            .sidebar.is-open .nav-link {
                color: #4a3540;
            }
            .sidebar.is-open .nav-link i {
                color: #C53678;
            }
            .sidebar.is-open .nav-link:hover {
                background: rgba(197, 54, 120, 0.09);
                color: #8f1f56;
            }
            .sidebar.is-open .nav-link.active {
