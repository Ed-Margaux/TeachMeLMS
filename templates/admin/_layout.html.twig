                           <div class="small text-muted">{{ app.user ? app.user.email : '' }}</div>
                       </div>
                   </a>
                   <div class="dropdown">
                       <div class="user-avatar" type="button" id="userDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                           {% if app.user and app.user.image %}
                               <img src="{{ asset('uploads/users/' ~ app.user.image) }}" alt="{{ app.user.fullName }}" style="width: 100%; height: 100%; border-radius: 50%; object-fit: cover;">
