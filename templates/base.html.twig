<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{% block title %}Teach Me - Learn. Love. Language.{% endblock %}</title>
        <link rel="icon" type="image/png" href="{{ asset('img/tmicon.png') }}">
        <link rel="apple-touch-icon" href="{{ asset('img/tmicon.png') }}">
        {% block stylesheets %}
            <link rel="stylesheet" href="{{ asset('styles/public/page-bg-elements.css') }}">
        {% endblock %}

        {% block javascripts %}
        {% endblock %}
    </head>
    <body>
        <div class="page-content-layer">
            {% block body %}{% endblock %}
        </div>
        {# Decor last in DOM + lower z-index so it never sits above UI or steal events #}
        {% include 'partials/_page_bg_elements.html.twig' %}
    </body>
</html>
