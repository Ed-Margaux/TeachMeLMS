{% extends 'base.html.twig' %}

{% block title %}Sign in — Teach Me{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Lato:ital,wght@0,400;0,600;0,700;1,400&family=Merriweather:ital,wght@0,700;0,900;1,700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="{{ asset('styles/public/public-footer.css') }}">
    <link rel="stylesheet" href="{{ asset('styles/public/login.css') }}">
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="{{ asset('js/password-toggle.js') }}" defer></script>
{% endblock %}

{% block body %}
<div class="login-page login-page--signin">
    <div class="login-split login-split--signin">
        <div class="login-split__panel">
            <header class="login-split__header">
                {% include 'partials/_tm_brand_logos.html.twig' with { variant: 'split' } %}
            </header>
            <div class="login-split__inner">
                <h1 class="login-split__title">Get Started Now</h1>
                <p class="login-split__lead">Enter your credentials to access your account</p>

                <div class="login-split__social">
                    <a href="{{ path('hwi_oauth_service_redirect', { service: 'google' }) }}" class="login-split__social-btn">
                        <svg width="20" height="20" viewBox="0 0 24 24" aria-hidden="true">
                            <path fill="currentColor" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
                            <path fill="currentColor" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
                            <path fill="currentColor" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
                            <path fill="currentColor" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
                        </svg>
                        <span class="login-split__social-label">Log in with Google</span>
                    </a>
                </div>

                <div class="login-split__rule" role="separator" aria-hidden="true"><span>or</span></div>

                {% if error %}
                    <div class="login-split__alert" role="alert">
                        <strong>We couldn’t sign you in.</strong><br>
                        {{ error.messageKey|trans(error.messageData, 'security') }}
                    </div>
                {% endif %}

                <form method="post" action="{{ path('app_login') }}" autocomplete="on">
                    <div class="login-split__field">
                        <label class="login-split__label" for="inputEmail">Email address</label>
                        <input
                            type="email"
                            id="inputEmail"
                            name="_username"
                            class="login-split__input"
                            value="{{ last_username|default('') }}"
                            autocomplete="email"
                            required
                            autofocus
                            placeholder="you@example.com"
                        >
                    </div>
                    <div class="login-split__field">
                        <label class="login-split__label" for="inputPassword">Password</label>
                        <div class="login-split__password-wrap">
                            <input
                                type="password"
                                id="inputPassword"
                                name="_password"
                                class="login-split__input login-split__input--with-toggle"
                                autocomplete="current-password"
                                required
                                placeholder="••••••••"
                            >
                            <button
                                type="button"
                                class="login-split__password-toggle"
                                data-password-toggle
                                aria-controls="inputPassword"
                                aria-label="Show password"
                                aria-pressed="false"
                            >
                                <span class="login-split__password-toggle-icon login-split__password-toggle-icon--show" aria-hidden="true">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" viewBox="0 0 24 24" stroke-width="1.6" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 0 1 0-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178Z" />
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                                    </svg>
                                </span>
                                <span class="login-split__password-toggle-icon login-split__password-toggle-icon--hide" hidden aria-hidden="true">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" viewBox="0 0 24 24" stroke-width="1.6" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M3.98 8.223A10.477 10.477 0 0 0 1.934 12C3.226 16.338 7.244 19.5 12 19.5c.993 0 1.953-.138 2.863-.395M6.228 6.228A10.45 10.45 0 0 1 12 4.5c4.756 0 8.773 3.162 10.065 7.498a10.523 10.523 0 0 1-4.293 5.774M6.228 6.228 3 3m3.228 3.228 3.65 3.65m7.894 7.894L21 21M12 12h.01" />
                                    </svg>
                                </span>
                            </button>
                        </div>
                    </div>

                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                    <div class="login-split__row">
                        <label class="login-split__remember">
                            <input type="checkbox" name="_remember_me" value="1">
                            Remember me
                        </label>
                        <a class="login-split__link" href="{{ path('app_contact') }}">Forgot password?</a>
                    </div>

                    <button type="submit" class="login-split__submit">Sign in</button>
                </form>

                <p class="login-split__register">
                    New here?
                    <a href="{{ path('app_register') }}">Create a Teach Me account</a>
                </p>

                <p class="login-split__legal">
                    By continuing, you agree to Teach Me’s
                    <a href="{{ path('app_home') }}#terms">Terms of Service</a>
                    and
                    <a href="{{ path('app_home') }}#privacy">Privacy Policy</a>.
                </p>
            </div>
        </div>

        <div
            class="login-split__visual"
            aria-hidden="true"
            style="background-image: linear-gradient(135deg, rgba(26, 39, 68, 0.82) 0%, rgba(197, 54, 120, 0.28) 45%, rgba(255, 88, 65, 0.22) 100%), url('{{ asset('img/stud.jpg') }}'); background-size: cover; background-position: center;"
        ></div>
    </div>
</div>
{% endblock %}
