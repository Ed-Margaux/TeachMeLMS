{% extends 'base.html.twig' %}

{% block title %}Login - Teach Me{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <style>
        body {
            background-image: url('{{ asset('img/chldrens.jpg') }}');
            background-size: cover;
            background-position: center;
            background-repeat: no-repeat;
            background-attachment: fixed;
            min-height: 100vh;
            display: flex;
            align-items: center;    
            justify-content: center;
            position: relative; 
        }
        body::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: linear-gradient(135deg, rgba(197, 54, 120, 0.7) 0%, rgba(237, 100, 166, 0.7) 100%);
            z-index: 0;
        }
        .login-container {
            background: rgba(252, 255, 233, 0.77);
            border-radius: 8px;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.15);
            padding: 2.5rem 2rem;
            max-width: 420px;
            width: 100%;
            position: relative;
            z-index: 1;
        }
        .login-logo {
            text-align: center;
            margin-bottom: 1.5rem;
        }
        .login-logo img {
            max-width: 200px;
            height: auto;
        }
        .login-title {
            text-align: center;
            color: #2c2c2c;
            font-weight: 600;
            margin-bottom: 1.5rem;
            font-size: 1.75rem;
        }
        .form-label {
            font-size: 14px;
            font-weight: 500;
            color: #2c2c2c;
            margin-bottom: 8px;
        }
        .form-control {
            border-radius: 6px;
            border: 1px solid #e0e0e0;
            padding: 12px 16px;
            font-size: 16px;
        }
        .form-control:focus {
            border-color: #ED64A6;
            box-shadow: 0 0 0 0.2rem rgba(237, 100, 166, 0.25);
        }
        .btn-login {
            background: linear-gradient(135deg, #C53678, #ED64A6);
            border: none;
            color: white;
            font-weight: 600;
            padding: 12px;
            border-radius: 6px;
            width: 100%;
            font-size: 16px;
            transition: all 0.3s ease;
        }
        .btn-login:hover {
            background: linear-gradient(135deg, #B02D6B, #D8559A);
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(197, 54, 120, 0.3);
        }
        .alert-danger {
            border-radius: 6px;
            border: none;
            background-color: #f8d7da;
            color: #721c24;
            font-size: 14px;
            padding: 12px 16px;
        }
        .mb-3 {
            margin-bottom: 1rem !important;
        }
        .mb-4 {
            margin-bottom: 1.5rem !important;
        }
    </style>
{% endblock %}

{% block body %}
<div class="login-container">
    <div class="login-logo">
        <img src="{{ asset('img/tmMainlogo.png') }}" alt="Teach Me - Learn. Love. Language.">
    </div>
    <h1 class="login-title">Welcome Back</h1>

    {% if error %}
        <div class="alert alert-danger mb-3">
            <strong>Login Error:</strong><br>
            {{ error.messageKey|trans(error.messageData, 'security') }}<br>
            <small>Error code: {{ error.messageKey }}</small>
        </div>
    {% endif %}

    <form method="post" action="{{ path('app_login') }}">
        <div class="mb-3">
            <label for="inputEmail" class="form-label">Email</label>
            <input type="email" value="{{ error ? last_username : '' }}" name="_username" id="inputEmail" class="form-control" autocomplete="email" required autofocus>
        </div>
        <div class="mb-4">
            <label for="inputPassword" class="form-label">Password</label>
            <input type="password" name="_password" id="inputPassword" class="form-control" autocomplete="current-password" required>
        </div>

        <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

        <button class="btn btn-login" type="submit">
            Sign in
        </button>
    </form>

</div>
{% endblock %}
