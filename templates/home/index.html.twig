        </div>
    </div>
</section>

<section class="section section--how-it-works" id="how-it-works">
    <div class="how-it-works-split">
        <div class="how-it-works-split__panel">
            <svg class="how-it-works-split__deco how-it-works-split__deco--balloons" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 120 100" fill="none" aria-hidden="true">
                <path stroke="rgba(237, 100, 166, 0.35)" stroke-width="1.5" d="M20 88c8-18 12-32 8-48M35 90c4-14 6-28 2-42M50 92c2-10 4-22 0-36"/>
                <ellipse cx="22" cy="28" rx="14" ry="18" stroke="rgba(197, 54, 120, 0.38)" stroke-width="1.5"/>
                <ellipse cx="48" cy="22" rx="12" ry="15" stroke="rgba(237, 100, 166, 0.32)" stroke-width="1.5"/>
            </svg>
            <svg class="how-it-works-split__deco how-it-works-split__deco--cloud" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 60" fill="none" aria-hidden="true">
                <path stroke="rgba(197, 54, 120, 0.28)" stroke-width="1.5" d="M10 42c0-8 6-14 14-14h4c2-10 12-16 22-12 4-8 14-12 22-8 8 4 12 14 8 22 6 2 10 8 8 14-2 8-10 12-18 10H18c-6 0-10-4-8-12z"/>
