{% extends 'base.html.twig' %}

{% block title %}Teach Me — Learn. Love. Language.{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    {% include 'partials/_public_header_styles.html.twig' %}
    <link rel="stylesheet" href="{{ asset('styles/public/kidso-public.css') }}">
    <link rel="stylesheet" href="{{ asset('styles/public/home.css') }}">
    <link rel="stylesheet" href="{{ asset('styles/public/public-footer.css') }}">
    <link rel="stylesheet" href="{{ asset('styles/public/public-animations.css') }}">
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="{{ asset('js/public-animations.js') }}" defer></script>
{% endblock %}

{% block body %}
<div class="page-home">
{% include 'partials/_public_header.html.twig' with { variant: 'landing' } %}

<main>
    <section class="hero" id="top">
        <div class="hero-content">
            <div class="hero-copy">
                <p class="hero__eyebrow">Welcome to Teach Me</p>
                <h1>Learn faster with your <span class="hero-accent">best</span> language tutor.</h1>
                <p>Personalized, fun, and interactive lessons designed to help kids grow confidently in any language.</p>
                <a href="#how-it-works" class="btn-cta">How it works</a>
            </div>
            <div class="hero-image">
                <img src="{{ asset('img/1stud.jpg') }}" alt="Student learning online with tutor" />
            </div>
        </div>
    </section>
</main>

<section class="section section--services" id="services">
    <div class="section-inner">
        <div class="km-section-head">
            <p class="km-eyebrow">Our services</p>
            <h2>What we provide</h2>
            <p class="section-lead">Everything families need for structured, joyful language learning—online, on your schedule.</p>
        </div>
        <div class="km-services-grid">
            <article class="km-service-card">
                <img class="km-service-card__img" src="{{ asset('img/services/tutor.jpg') }}" alt="Tutor supporting a young learner during a session" width="640" height="800" loading="lazy" decoding="async" />
                <div class="km-service-card__overlay" aria-hidden="true"></div>
                <div class="km-service-card__body">
                    <h3 class="km-service-card__title">Live tutoring</h3>
                    <div class="km-service-card__reveal">
                        <p class="km-service-card__text">One-to-one sessions with tutors who adapt pace, topics, and activities to your child.</p>
                        <a class="km-service-card__link" href="#how-it-works">See how it works</a>
                    </div>
                </div>
            </article>
            <article class="km-service-card">
                <img class="km-service-card__img" src="{{ asset('img/services/plan.jpg') }}" alt="Planning learning goals and lesson notes" width="640" height="800" loading="lazy" decoding="async" />
                <div class="km-service-card__overlay" aria-hidden="true"></div>
                <div class="km-service-card__body">
                    <h3 class="km-service-card__title">Goal-based plans</h3>
                    <div class="km-service-card__reveal">
                        <p class="km-service-card__text">Homework help, fluency, or exam prep—clear goals and feedback after every lesson.</p>
                        <a class="km-service-card__link" href="#benefits">Why families choose us</a>
                    </div>
                </div>
            </article>
            <article class="km-service-card">
                <img class="km-service-card__img" src="{{ asset('img/services/parent.jpg') }}" alt="Parent and child learning together at home" width="640" height="800" loading="lazy" decoding="async" />
                <div class="km-service-card__overlay" aria-hidden="true"></div>
                <div class="km-service-card__body">
                    <h3 class="km-service-card__title">Parent partnership</h3>
                    <div class="km-service-card__reveal">
                        <p class="km-service-card__text">Stay informed with simple updates so you know what was practiced and what’s next.</p>
                        <a class="km-service-card__link" href="{{ path('app_contact') }}">Contact us</a>
                    </div>
                </div>
            </article>
        </div>
    </div>
</section>

<section class="section alt section--about-preview" id="about-teach">
    <div class="section-inner km-about-split">
        <div class="km-about-split__media">
            <img src="{{ asset('img/studon.png') }}" alt="Children learning together in a bright, welcoming space" width="800" height="600" loading="lazy" decoding="async" />
        </div>
        <div class="km-about-split__content">
            <div class="km-section-head km-section-head--left">
                <p class="km-eyebrow">About us</p>
                <h2 class="km-title">Get special care for your learner</h2>
                <p class="section-lead">Teach Me connects families with tutors who make language practice feel structured, encouraging, and fun—whether your child is shy, curious, or ready for a challenge.</p>
                <a class="km-link-btn" href="{{ path('app_about') }}">Explore more</a>
            </div>
            {% include 'partials/_home_platform_stats.html.twig' with { variant: 'about_inline' } %}
        </div>
    </div>
</section>

<section class="section section--offerings" id="offerings">
    <div class="section-inner">
        <div class="km-section-head">
            <p class="km-eyebrow">Learning paths</p>
            <h2>Get the best classes with us</h2>
            <p class="section-lead">Popular focus areas—your tutor tailors content to your child’s age and level.</p>
        </div>
        <div class="km-offerings-grid">
            <article class="km-offering-card">
                <div class="km-offering-card__thumb km-offering-card__thumb--img" aria-hidden="true">
                    <img src="{{ asset('img/paths/speak.png') }}" alt="" width="640" height="440" loading="lazy" decoding="async" />
                </div>
                <div class="km-offering-card__body">
                    <h3 class="km-offering-card__title">Speaking &amp; listening</h3>
                    <p class="km-offering-card__text">Conversation games, pronunciation, and confidence in real-life topics.</p>
                    <ul class="km-offering-card__meta">
                        <li>Ages: 6–14</li>
                        <li>Flexible scheduling</li>
                    </ul>
                </div>
            </article>
            <article class="km-offering-card">
                <div class="km-offering-card__thumb km-offering-card__thumb--img" aria-hidden="true">
                    <img src="{{ asset('img/paths/read.png') }}" alt="" width="640" height="440" loading="lazy" decoding="async" />
                </div>
                <div class="km-offering-card__body">
                    <h3 class="km-offering-card__title">Reading &amp; writing</h3>
                    <p class="km-offering-card__text">Comprehension, vocabulary, and short writing with gentle feedback.</p>
                    <ul class="km-offering-card__meta">
                        <li>Ages: 6–14</li>
                        <li>Aligned to school goals</li>
                    </ul>
                </div>
            </article>
            <article class="km-offering-card">
                <div class="km-offering-card__thumb km-offering-card__thumb--img" aria-hidden="true">
                    <img src="{{ asset('img/paths/exam.png') }}" alt="" width="640" height="440" loading="lazy" decoding="async" />
                </div>
                <div class="km-offering-card__body">
                    <h3 class="km-offering-card__title">Exam prep</h3>
                    <p class="km-offering-card__text">Structured drills and strategies for tests without burning out.</p>
                    <ul class="km-offering-card__meta">
                        <li>Grades 4–10</li>
                        <li>Practice + review</li>
                    </ul>
                </div>
            </article>
            <article class="km-offering-card">
                <div class="km-offering-card__thumb km-offering-card__thumb--img" aria-hidden="true">
                    <img src="{{ asset('img/paths/beginner.png') }}" alt="" width="640" height="440" loading="lazy" decoding="async" />
                </div>
                <div class="km-offering-card__body">
                    <h3 class="km-offering-card__title">Beginner friendly</h3>
                    <p class="km-offering-card__text">Patient tutors who build basics with games, stories, and repetition.</p>
                    <ul class="km-offering-card__meta">
                        <li>First-time learners</li>
                        <li>Low-pressure pace</li>
                    </ul>
                </div>
