<div class="row mb-4" data-tm-sync-summary>
    <div class="col-md-4">
        <div class="summary-card grades">
            <div class="summary-card-icon">
                <i class="bi bi-mortarboard-fill"></i>
            </div>
            <div class="summary-card-content">
                <div class="summary-card-label">Grade Levels</div>
                <div class="summary-card-value" data-tm-total-grades>{{ totalGrades }}</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="summary-card total">
            <div class="summary-card-icon">
                <i class="bi bi-people-fill"></i>
            </div>
            <div class="summary-card-content">
                <div class="summary-card-label">Total Students</div>
                <div class="summary-card-value" data-tm-total-students>{{ totalStudents }}</div>
            </div>
        </div>
    </div>
</div>

<div data-tm-sync-cards>
{% if students|length > 0 %}
    <div class="row">
        {% for student in students %}
            <div class="col-md-6 col-lg-4">
                <div class="profile-card">
                    <div class="profile-header">
                        {% if student.image %}
                            <img src="{{ asset('uploads/students/' ~ student.image) }}" alt="{{ student.fullName }}" class="profile-image">
                        {% else %}
                            <div class="profile-image-placeholder">
                                <i class="bi bi-person"></i>
                            </div>
                        {% endif %}
                        <div class="profile-info">
                            <div class="profile-name">{{ student.fullName }}</div>
                            <div class="profile-email">{{ student.email }}</div>
                            {% if student.parentEmail %}
                                <div class="profile-email text-muted small">Parent: {{ student.parentEmail }}</div>
                            {% endif %}
                        </div>
                        <div class="profile-menu">
                            <button class="profile-menu-btn" type="button" data-bs-toggle="dropdown">
                                <i class="bi bi-three-dots-vertical"></i>
                            </button>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" href="{{ path('app_student_show', {'id': student.id}) }}"><i class="bi bi-eye me-2"></i>View</a></li>
                                {% if is_granted('ROLE_ADMIN') or (student.createdBy and student.createdBy.id == app.user.id) %}
                                    <li><a class="dropdown-item" href="{{ path('app_student_edit', {'id': student.id}) }}"><i class="bi bi-pencil me-2"></i>Edit</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <form method="post" action="{{ path('app_student_delete', {'id': student.id}) }}" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this student?');">
                                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ student.id) }}">
                                            <button type="submit" class="dropdown-item text-danger"><i class="bi bi-trash me-2"></i>Delete</button>
                                        </form>
                                    </li>
                                {% endif %}
                            </ul>
                        </div>
                    </div>

                    <div class="profile-details">
                        <div class="profile-detail-item">
                            <span class="profile-detail-label">Grade:</span>
                            <span class="profile-detail-value">{{ student.grade ?? '-' }}</span>
                        </div>
                        <div class="profile-detail-item">
                            <span class="profile-detail-label">Phone:</span>
                            <span class="profile-detail-value">{{ student.phone ?? '-' }}</span>
                        </div>
                        <div class="profile-detail-item" style="grid-column: 1 / -1;">
                            <span class="profile-detail-label">Joined:</span>
                            <span class="profile-detail-value">{{ student.createdAt ? student.createdAt|date('M d, Y') : '-' }}</span>
                        </div>
                    </div>

                    <div class="profile-footer">
                        <span class="status-badge">Active</span>
                        <div class="profile-actions">
                            <a href="{{ path('app_student_show', {'id': student.id}) }}" class="action-btn view" title="View">
                                <i class="bi bi-eye"></i>
                            </a>
                            {% if is_granted('ROLE_ADMIN') or (student.createdBy and student.createdBy.id == app.user.id) %}
                                <a href="{{ path('app_student_edit', {'id': student.id}) }}" class="action-btn edit" title="Edit">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <form method="post" action="{{ path('app_student_delete', {'id': student.id}) }}" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this student?');">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ student.id) }}">
                                    <button type="submit" class="action-btn" style="background: #dc3545; color: white;" title="Delete">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>
        {% endfor %}
    </div>
{% else %}
    <div class="card shadow-sm">
        <div class="card-body text-center py-5">
            <i class="bi bi-people text-muted" style="font-size: 3rem;"></i>
            <p class="text-muted mt-3">No students found.</p>
        </div>
    </div>
{% endif %}
</div>
