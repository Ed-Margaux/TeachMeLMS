<div style="font-family: Arial, sans-serif; line-height: 1.6; color: #2c2c2c;">
    <h2 style="margin: 0 0 12px 0;">Verify your Teach Me account</h2>
    <p style="margin: 0 0 12px 0;">
        Hi {{ user.fullName ?? 'there' }}, please verify your email to complete your registration.
    </p>
    <p style="margin: 0 0 14px 0;">
        <a href="{{ verifyUrl }}" style="display:inline-block; padding: 12px 18px; border-radius: 10px; background: #ED64A6; color: #fff; text-decoration: none; font-weight: 700;">
            Verify Email
        </a>
    </p>
    <p style="margin: 0; color: #666; font-size: 13px;">
        This link expires on {{ expiresAt|date('M d, Y H:i') }}.
    </p>
</div>

