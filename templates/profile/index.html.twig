{% extends 'admin/_layout.html.twig' %}

{% block title %}Profile{% endblock %}
{% block admin_title %}Profile Settings{% endblock %}

{% block admin_content %}
<style>
    .profile-view-card {
        background: var(--bg-card);
        border-radius: 12px;
        box-shadow: var(--shadow-md);
        padding: 2rem;
        transition: background-color 0.3s ease;
    }
    .profile-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2rem;
        padding-bottom: 1.5rem;
        border-bottom: 2px solid var(--pink-primary);
    }
    .profile-avatar {
        width: 80px;
        height: 80px;
        border-radius: 50%;
        background: linear-gradient(135deg, var(--pink-secondary), var(--pink-primary));
        color: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: bold;
        font-size: 2rem;
        margin-bottom: 1rem;
    }
    .profile-info-item {
        padding: 1rem 0;
        border-bottom: 1px solid var(--border-light);
    }
    .profile-info-item:last-child {
        border-bottom: none;
    }
    .profile-info-label {
        font-size: 12px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: var(--text-secondary);
        font-weight: 600;
        margin-bottom: 0.5rem;
    }
    .profile-info-value {
        font-size: 16px;
        color: var(--text-primary);
        font-weight: 500;
    }
    .profile-role-badge {
        display: inline-block;
        padding: 6px 12px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }
    .profile-role-badge.admin {
        background: rgba(237, 100, 166, 0.2);
        color: var(--pink-primary);
    }
    .profile-role-badge.staff {
        background: rgba(197, 54, 120, 0.2);
        color: var(--pink-secondary);
    }
    .profile-role-badge.user {
        background: rgba(108, 92, 231, 0.2);
        color: #6c5ce7;
    }
</style>

<div class="profile-view-card">
    <div class="profile-header">
        <div>
            <h2 class="h4 mb-0" style="color: var(--text-primary); font-weight: 600;">My Profile</h2>
            <p class="text-muted mb-0 mt-1">View and manage your account information</p>
        </div>
        <a href="{{ path('app_profile_edit') }}" class="btn btn-brand">
            <i class="bi bi-pencil me-2"></i>Edit Profile
        </a>
    </div>

    <div class="row">
        <div class="col-md-4 text-center mb-4 mb-md-0">
            {% if user.image %}
                <div class="profile-avatar mx-auto" style="background: none; border: 3px solid var(--pink-primary); padding: 3px;">
                    <img src="{{ asset('uploads/users/' ~ user.image) }}" alt="{{ user.fullName }}" style="width: 100%; height: 100%; border-radius: 50%; object-fit: cover;">
                </div>
            {% else %}
                <div class="profile-avatar mx-auto">
                    {{ user.firstName|slice(0,1)|upper }}{{ user.lastName|slice(0,1)|upper }}
                </div>
            {% endif %}
            <h4 class="mt-3 mb-1" style="color: var(--text-primary);">{{ user.fullName }}</h4>
            <p class="text-muted mb-2">{{ user.email }}</p>
            <div>
                {% if 'ROLE_ADMIN' in user.roles %}
                    <span class="profile-role-badge admin">Admin</span>
                {% elseif 'ROLE_STAFF' in user.roles %}
                    <span class="profile-role-badge staff">Staff</span>
                {% else %}
                    <span class="profile-role-badge user">User</span>
                {% endif %}
            </div>
        </div>
        <div class="col-md-8">
            <div class="profile-info-item">
                <div class="profile-info-label">First Name</div>
                <div class="profile-info-value">{{ user.firstName }}</div>
            </div>
            <div class="profile-info-item">
                <div class="profile-info-label">Last Name</div>
                <div class="profile-info-value">{{ user.lastName }}</div>
            </div>
            <div class="profile-info-item">
                <div class="profile-info-label">Email Address</div>
                <div class="profile-info-value">{{ user.email }}</div>
            </div>
            <div class="profile-info-item">
                <div class="profile-info-label">Account Status</div>
                <div class="profile-info-value">
                    <span class="badge bg-{{ user.status == 'active' ? 'success' : 'danger' }}">
                        {{ user.status|capitalize }}
                    </span>
                </div>
            </div>
            <div class="profile-info-item">
                <div class="profile-info-label">Member Since</div>
                <div class="profile-info-value">{{ user.createdAt ? user.createdAt|date('F d, Y') : 'N/A' }}</div>
            </div>
            {% if user.updatedAt %}
            <div class="profile-info-item">
                <div class="profile-info-label">Last Updated</div>
                <div class="profile-info-value">{{ user.updatedAt|date('F d, Y') }}</div>
            </div>
            {% endif %}
        </div>
    </div>

    <div class="mt-4 pt-4 border-top" style="border-color: var(--border-light);">
        <div class="d-flex gap-2">
            <a href="{{ path('app_profile_edit') }}" class="btn btn-brand">
                <i class="bi bi-pencil me-2"></i>Edit Profile
            </a>
            <a href="{{ path('app_admin_dashboard') }}" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left me-2"></i>Back to Dashboard
            </a>
        </div>
    </div>
</div>
{% endblock %}
